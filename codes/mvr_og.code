rule("Rein Clip into Skirmish Mercy Spawn execute")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Global.D != 0;
		Global.SpawnClipRein == True;
		Remove From Array(Append To Array(Players Within Radius(Global.D[0], 1.500, Team 1, Off), Players Within Radius(Global.D[1], 1.500,
			Team 1, Off)), Global.SpawnNoClip) != Remove From Array(Global.SpawnNoClip, Append To Array(Players Within Radius(Global.D[0],
			1.500, Team 1, Off), Players Within Radius(Global.D[1], 1.500, Team 1, Off)));
	}

	actions
	{
		Global.SpawnNoClip = Append To Array(Players Within Radius(Global.D[0], 1.500, Team 1, Off), Players Within Radius(Global.D[1],
			1.500, Team 1, Off));
		Disable Movement Collision With Environment(Global.SpawnNoClip, False);
		Enable Movement Collision With Environment(Remove From Array(All Players(Team 1), Global.SpawnNoClip));
	}
}

rule("Flashpoint rein TP active message")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		(Current Map == Map(New Junk City)) != (Current Map == Map(Suravasa));
		Match Time <= 160;
	}

	actions
	{
		Big Message(All Players(All Teams), Custom String("Rein {0} Teleporters {1} Active", Hero Icon String(Hero(Reinhardt)),
			Ability Icon String(Hero(Symmetra), Button(Ability 2))));
	}
}

rule("Ensure mercy dies in one shot")
{
	event
	{
		Player Dealt Damage;
		Team 1;
		All;
	}

	conditions
	{
		Is Alive(Victim) == True;
		Team Of(Victim) == Team 2;
	}

	actions
	{
		Kill(Victim, Attacker);
	}
}