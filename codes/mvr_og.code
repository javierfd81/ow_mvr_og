rule("SetWallImmune SUBROUTINE")
{
	event
	{
		Subroutine;
		SetWallImmune;
	}

	actions
	{
		Event Player.IsImmuneToWall = True;
		If(Current Map == Map(Blizzard World));
			Wait Until(Z Component Of(Position Of(Event Player)) >= 70 || (Z Component Of(Position Of(Event Player)) >= 54 && Y Component Of(
				Position Of(Event Player)) < 4.900), 9999);
		Else If(Current Map == Map(Horizon Lunar Colony));
			Wait Until(Z Component Of(Position Of(Event Player)) <= -79, 9999);
		Else If(Current Map == Map(Junkertown));
			Wait Until(X Component Of(Position Of(Event Player)) >= -73.875, 9999);
		Else;
			Wait Until(Z Component Of(Position Of(Event Player)) >= 53, 9999);
		End;
		Event Player.IsImmuneToWall = False;
	}
}

rule("Wall to halve flashpoint map size X+")
