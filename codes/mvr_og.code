rule("Set Death Orbs")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		If(Current Map == Map(Busan));
			Global.DeathOrbPositions = Array(Vector(177.164, -9, 276.085), Vector(279.039, -9, 228.835));
			Global.DeathOrbRadii = Array(12, 12);
		Else If(Current Map == Map(Castillo));
			Global.DeathOrbPositions = Array(Vector(-72.627, 42.280, 21.283));
			Global.DeathOrbRadii = Array(0.690);
		Else If(Current Map == Map(Circuit royal));
			Global.DeathOrbPositions = Array(Vector(-83.500, 18.500, -56.500));
			Global.DeathOrbRadii = Array(5.500);
		Else If(Current Map == Map(Ilios Lighthouse));
			Global.DeathOrbPositions = Array(Vector(278.610, -15.794, -66.113));
			Global.DeathOrbRadii = Array(1.690);
		Else If(Current Map == Map(Ilios Well));
			Global.DeathOrbPositions = Array(Vector(-168.183, 2.213, -39.329), Vector(-231.659, 2.260, 23.936));
			Global.DeathOrbRadii = Array(1.750, 1.750);
		Else If(Current Map == Map(King's Row));
			Global.DeathOrbPositions = Array(Vector(-93.835, 19.460, 43.144));
			Global.DeathOrbRadii = Array(2);
		Else If(Current Map == Map(Lijiang Night Market));
			Global.DeathOrbPositions = Array(Vector(78.928, -15, -72.330), Vector(-79.715, -13.595, -78.171), Vector(-95.246, -17.014,
				-70.898));
			Global.DeathOrbRadii = Array(26, 15, 14);
		End;
		For Global Variable(Loop, 0, Count Of(Global.DeathOrbPositions), 1);
			Create Effect(All Players(All Teams), Sphere, Color(Red), Global.DeathOrbPositions[Global.Loop], Global.DeathOrbRadii[Global.Loop],
				Visible To);
		End;
	}
}

rule("Execute Death Orbs")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is True For Any(Global.DeathOrbPositions, Distance Between(Event Player, Current Array Element)
			< Global.DeathOrbRadii[Current Array Index]) == True;
		Is Alive(Event Player) == True;
	}

	actions
	{
		Call Subroutine(DeathOrbKill);
	}
}

rule("Death Orb Kill Subroutine")
{
	event
	{
		Subroutine;
		DeathOrbKill;
	}

	actions
	{
		If(Current Map == Map(Paris));
			Big Message(Event Player, Custom String("Get Back in Sphere!"));
		Else;
			Big Message(Event Player, Custom String("Don't Hide Here"));
		End;
		If(Current Map == Map(Busan) || Current Map == Map(Circuit royal) || Current Map == Map(Lijiang Night Market));
			Kill(Event Player, Null);
			If(Distance Between(Event Player, Global.DeathOrbPositions[0]) > 69);
				Event Player.mercydeath = True;
				If(Current Map == Map(Busan));
					Teleport(Event Player, Global.TDMSpawnPositions[0]);
				End;
				If(Current Map == Map(Lijiang Night Market));
					Teleport(Event Player, Vector(-63.586, 3.479, -47.659));
				End;
				Wait(0.250, Ignore Condition);
				Event Player.mercydeath = False;
			Else If(Current Map == Map(Busan) || Current Map == Map(Circuit royal));
				Event Player.mercydeath = True;
				Teleport(Event Player, Global.TDMSpawnPositions[1]);
				Wait(0.250, Ignore Condition);
				Event Player.mercydeath = False;
			End;
		Else;
			Wait(3, Abort When False);
			Apply Impulse(Event Player, Up, 18, To World, Cancel Contrary Motion);
			Big Message(Event Player, Custom String("illegal hiding spot."));
			Wait(0.750, Ignore Condition);
			Event Player.mercydeath = True;
			Kill(Event Player, Event Player);
			Wait(0.250, Ignore Condition);
			Event Player.mercydeath = False;
		End;
	}
}

