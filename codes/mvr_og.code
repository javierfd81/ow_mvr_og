rule("Rein sacrifice health for ult charge")
{
	event
	{
		Ongoing - Each Player;
		Team 1;
		All;
	}

	conditions
	{
		Workshop Setting Toggle(Custom String("Rein Settings"), Custom String("Sacrifice Health for Ult Charge"), False, 0) == True;
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Ultimate Charge Percent(Event Player) < 100;
	}

	actions
	{
		Wait(1, Abort When False);
		Create Effect(All Players(All Teams), Bad Aura, Color(Red), Event Player, 1, Position and Radius);
		Event Player.MercyDeathSparkles[2] = Last Created Entity;
		Create Effect(All Players(All Teams), Energy Sound, Color(White), Event Player, Event Player.HealthSacrificed * 6,
			Position and Radius);
		Event Player.MercyDeathSparkles[1] = Last Created Entity;
		Chase Player Variable At Rate(Event Player, HealthSacrificed, 20, 5, None);
		Start Damage Over Time(Event Player, Null, 4, 2000);
		Set Move Speed(Event Player, 70);
		Wait Until(!Is Button Held(Event Player, Button(Ultimate)) || Is Dead(Event Player) || Ultimate Charge Percent(Event Player)
			+ Event Player.HealthSacrificed >= 100, 4);
		disabled Wait Until(!Is Button Held(Event Player, Button(Ultimate)) || Ultimate Charge Percent(Event Player)
			+ Event Player.HealthSacrificed >= 100, 4);
		Stop Chasing Player Variable(Event Player, HealthSacrificed);
		Set Ultimate Charge(Event Player, Ultimate Charge Percent(Event Player) + Event Player.HealthSacrificed);
		Event Player.HealthSacrificed = 0;
		Stop Damage Over Time(Last Damage Over Time ID);
		Set Move Speed(Event Player, 100);
		Destroy Effect(Event Player.MercyDeathSparkles[2]);
		Destroy Effect(Event Player.MercyDeathSparkles[1]);
		Play Effect(All Players(All Teams), Good Explosion, Color(Blue), Event Player, 1);
		Play Effect(All Players(All Teams), Buff Impact Sound, Null, Event Player, 30);
	}
}

