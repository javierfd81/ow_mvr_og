rule("Rein Respawn on enviro death")
{
	event
	{
		Player Died;
		All;
		Reinhardt;
	}

	conditions
	{
		Attacker == Event Player;
		Workshop Setting Toggle(Custom String("Rein Settings"), Custom String("Respawn On Envir Death"), False, 0) == True;
		Is Game In Progress == True;
		(Global.RoundStart || Current Game Mode == Game Mode(Elimination)) == True;
		Event Player.mercydeath != True;
		Count Of(All Living Players(Team 1)) >= 1;
		Team Of(Event Player) == Team 1;
		Is Dead(Event Player) == True;
	}

	actions
	{
		Wait(0.250, Abort When False);
		If(Match Time >= 45);
			Big Message(All Players(All Teams), Custom String("Rein Respawning in 15 Seconds"));
		Else;
			Big Message(All Players(All Teams), Custom String("Reins will no longer respawn!"));
			Abort;
		End;
		Wait(15, Abort When False);
		Global.DeadRein = Event Player;
		Call Subroutine(RespawnRein);
	}
}

rule("RespawnRein SUBROUTINE")
{
	event
	{
		Subroutine;
		RespawnRein;
	}

	actions
	{
		If(Global.DeadRein != Null && Team Of(Global.DeadRein) == Team Of(Event Player));
			Attach Players(Global.DeadRein, Closest Player To(Global.DeadRein, Team Of(Global.DeadRein)), Vector(0, 1.690, -0.690));
			Wait(0.250, Ignore Condition);
			Play Effect(All Players(Opposite Team Of(Team Of(Global.DeadRein))), Bad Explosion, Color(Red), Farthest Player From(
				Global.DeadRein, Team Of(Global.DeadRein)), 100);
			Play Effect(All Players(Opposite Team Of(Team Of(Global.DeadRein))), Ring Explosion Sound, Color(White), Farthest Player From(
				Global.DeadRein, Team Of(Global.DeadRein)), 100);
			Play Effect(All Players(Team Of(Global.DeadRein)), Good Pickup Effect, Color(Green), Farthest Player From(Global.DeadRein, Team Of(
				Global.DeadRein)), 100);
			Play Effect(All Players(Team Of(Global.DeadRein)), Buff Impact Sound, Color(White), Farthest Player From(Global.DeadRein, Team Of(
				Global.DeadRein)), 100);
			Resurrect(Global.DeadRein);
			Start Scaling Player(Global.DeadRein, 0.400, False);
			Set Player Health(Global.DeadRein, Global.DeadRein.Health);
			Small Message(Global.DeadRein, Custom String("Jump or Crouch to Dismount"));
			If(Ultimate Charge Percent(Global.DeadRein) == 0);
				Set Ultimate Charge(Global.DeadRein, 1);
			End;
			Wait Until(Is Button Held(Global.DeadRein, Button(Jump)) || Is Button Held(Global.DeadRein, Button(Crouch)) || Is Button Held(
				Global.DeadRein, Button(Ability 1)) || Is Button Held(Global.DeadRein, Button(Melee)) || Ultimate Charge Percent(
				Global.DeadRein) == 0 || Is Dead(Farthest Player From(Global.DeadRein, Team Of(Global.DeadRein))), 5);
			Detach Players(Global.DeadRein);
			Stop Scaling Player(Global.DeadRein);
			Teleport(Global.DeadRein, Position Of(Global.DeadRein) + Vector(0, -1, 0));
			Global.DeadRein.IsInMap = Farthest Player From(Global.DeadRein, Team Of(Global.DeadRein)).IsInMap;
			If(Is Button Held(Global.DeadRein, Button(Jump)));
				Apply Impulse(Global.DeadRein, Up, 10, To World, Cancel Contrary Motion);
			End;
			If(!Is In Line of Sight(Event Player, Global.DeadRein, Barriers Do Not Block LOS));
				Teleport(Global.DeadRein, Event Player);
			End;
			Global.DeadRein = Null;
		End;
	}
}

