rule("Bubble execute")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Global.BubblePosition != 0;
		Current Game Mode != Game Mode(Skirmish);
		(Global.RoundStart || Current Game Mode == Game Mode(Elimination)) == True;
		Event Player.IsInMap == False;
		Is Alive(Event Player) == True;
		Distance Between(Event Player, Global.BubblePosition) >= 12.400;
	}

	actions
	{
		If(Current Map == Map(Paris));
			If(Z Component Of(Position Of(Event Player)) < -60);
				Abort;
			End;
			If(Team Of(Event Player) == Team 2);
				Call Subroutine(DeathOrbKill);
			End;
		Else;
			Teleport(Event Player, Ray Cast Hit Position(Vector(-75.985, 64.878, 27.998), (Position Of(Event Player)
				* 5 + Global.BubblePosition) / 6, Null, Event Player, False));
			Apply Impulse(Event Player, Direction Towards(Event Player, Global.BubblePosition), 8, To World, Cancel Contrary Motion);
		End;
	}
}

