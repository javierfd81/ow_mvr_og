				-101.250, 7, 6.250), Vector(-88.250, 6, -4.750), Vector(-91.695, 6, -8.125));
			Global.SkirmishSpawns = 1;
		Else If(Current Map == Map(Shambali Monastery));
			Global.TeleporterPositions = Array(Vector(-6.166, 8, -6.520), Vector(-6.159, 8, -11.077), Vector(6.810, 8, -6.489), Vector(6.848,
				8, -11.240));
			Global.SkirmishSpawns = 1;
		Else If(Current Map == Map(Suravasa));
			Global.TeleporterPositions = Array(Vector(-27, 3, 83), Vector(-27, 3, -83), Vector(37.300, 5, 42), Vector(33.500, 7, -42));
			Global.SkirmishSpawns = 1;
		Else If(Current Map == Map(Temple of Anubis) && Current Game Mode == Game Mode(Skirmish));
			Global.TeleporterPositions = Array(Vector(-11, -2, -39), Vector(-2.548, 0.770, -33.207), Vector(-1, -1.800, -14.384), Vector(5.145,
				0.770, -23.235), Vector(20.154, 0.710, -17.316), Vector(17.455, 0.770, -19.206));
			Global.SkirmishSpawns = 1;
		Else If(Current Map == Map(Volskaya Industries) && Current Game Mode == Game Mode(Skirmish));
			Global.TeleporterPositions = Array(Vector(-7.283, -6.980, -2.809), Vector(-1.576, -4.980, -7.854), Vector(-2, -5.880, 15.900),
				Vector(2.368, -4.980, 12), Vector(18.826, -5, 22.805), Vector(21.799, -4.980, 20.165));
			Global.SkirmishSpawns = 1;
		Else If(Current Map == Map(Watchpoint: Gibraltar));
			Global.TeleporterPositions = Array(Vector(15.500, -2, -134.250), Vector(10, -2, -132.250), Vector(21, -6, -159), Vector(17.600, -6,
				-160.500), Vector(17, 6, -130.500), Vector(15, 6, -128.500));
			Global.SkirmishSpawns = 1;
		End;
		Wait(1, Ignore Condition);
		If(Global.ExperimentalChargeOnlyMap && Is True For Any(Array(Map(Castillo), Map(Hollywood)),
			Current Array Element == Current Map));
			Global.TeleporterCD = 3;
		Else;
			Global.TeleporterCD = 5;
		End;
		If(Global.SkirmishSpawns == 0);
			For Global Variable(Loop, 0, Count Of(Global.TeleporterPositions), 2);
				Create Effect(All Players(All Teams), Ring, Color(Blue), Global.TeleporterPositions[Global.Loop], 1.500, Visible To);
				Create Effect(All Players(All Teams), Ring, Color(Blue), Global.TeleporterPositions[Global.Loop + 1], 1.500, Visible To);
			End;
		End;
	}
}

rule("Teleporter Use Rein")
{
	event
	{
		Ongoing - Each Player;
		Team 1;
		All;
	}

	conditions
	{
		Global.TeleporterPositions != 0;
		Is Jumping(Event Player) == True;
		Altitude Of(Event Player) < 0.690;
		Y Component Of(Velocity Of(Event Player)) > 0;
	}

	actions
	{
		For Player Variable(Event Player, TP, 0, Count Of(Global.TeleporterPositions), 1);
			If(Distance Between(Vector(X Component Of(Position Of(Event Player)), Y Component Of(Global.TeleporterPositions[Event Player.TP]),
				Z Component Of(Position Of(Event Player))), Global.TeleporterPositions[Event Player.TP]) < 1.750);
				If(Is In Line of Sight(Event Player, Vector(0, 0.500, 0) + Global.TeleporterPositions[Event Player.TP],
					Barriers Do Not Block LOS));
					If(Is True For Any(Array(Map(New Junk City), Map(Suravasa)), Current Map == Current Array Element) && Match Time > 160);
						Small Message(Event Player, Custom String("  Teleporter {0} not active yet!", Ability Icon String(Hero(Symmetra), Button(
							Ability 2))));
					Else;
						If(Event Player.TP % 2 == 0);
							Teleport(Event Player, Global.TeleporterPositions[Event Player.TP + 1]);
							Event Player.IsInMap = False;
						Else;
							Teleport(Event Player, Global.TeleporterPositions[Event Player.TP - 1]);
							Event Player.IsInMap = True;
						End;
						Play Effect(All Players(All Teams), Bad Pickup Effect, Color(Blue), Event Player, 1);
						Play Effect(All Players(All Teams), Buff Explosion Sound, Null, Event Player, 69);
						Event Player.TP = Count Of(Global.TeleporterPositions);
					End;
				End;
			End;
		End;
	}
}

rule("Teleporter Use Mercy")
{
	event
	{
		Ongoing - Each Player;
		Team 2;
		All;
	}

	conditions
	{
		Global.TeleporterPositions != 0;
		Global.SkirmishSpawns == 0;
		Is Jumping(Event Player) == True;
		Altitude Of(Event Player) < 0.690;
		Y Component Of(Velocity Of(Event Player)) > 0;
	}

	actions
	{
		For Player Variable(Event Player, TP, 0, Count Of(Global.TeleporterPositions), 1);
			If(Distance Between(Vector(X Component Of(Position Of(Event Player)), Y Component Of(Global.TeleporterPositions[Event Player.TP]),
				Z Component Of(Position Of(Event Player))), Global.TeleporterPositions[Event Player.TP]) < 1.750);
				If(Is In Line of Sight(Event Player, Vector(0, 0.500, 0) + Global.TeleporterPositions[Event Player.TP],
					Barriers Do Not Block LOS));
					If(Event Player.TeleporterCD == 0);
						If(Event Player.TP % 2 == 0);
							Teleport(Event Player, Global.TeleporterPositions[Event Player.TP + 1]);
							If(Current Map != Map(Rialto) || Event Player.TP != 0);
								Event Player.IsInMap = False;
							End;
						Else;
							Teleport(Event Player, Global.TeleporterPositions[Event Player.TP - 1]);
							Event Player.IsInMap = True;
						End;
						Event Player.TeleporterCD = Global.TeleporterCD;
						Chase Player Variable At Rate(Event Player, TeleporterCD, 0, 1, None);
						If(Array Contains(Array(Map(Ecopoint: Antarctica), Map(Ecopoint: Antarctica Winter), Map(Horizon Lunar Colony), Map(Rialto)),
							Current Map));
							Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[0], 1.500 * ((5 - Event Player.TeleporterCD) / 5),
								Visible To Position and Radius);
							Event Player.TeleporterRingCD[0] = Last Created Entity;
							Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[1], 1.500 * ((5 - Event Player.TeleporterCD) / 5),
								Visible To Position and Radius);
							Event Player.TeleporterRingCD[1] = Last Created Entity;
							Event Player.TP = True;
						Else;
							Event Player.TP = False;
						End;
						If(!Event Player.TP || Current Map == Map(Rialto));
							For Player Variable(Event Player, TP, Current Map == Map(Rialto) ? 1 : 0, Min(Count Of(Global.TeleporterPositions) / 2, 3), 1);
								If(Event Player.TP == 0);
									Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[1 - Event Player.IsInMap], 1.500 * ((
										5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
								Else If(Event Player.TP == 1);
									Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[3 - Event Player.IsInMap], 1.500 * ((
										5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
								Else;
									Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[5 - Event Player.IsInMap], 1.500 * ((
										5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
								End;
								Event Player.TeleporterRingCD[Event Player.TP + (Current Map == Map(Rialto) ? 1 : 0)] = Last Created Entity;
							End;
							If(Current Map == Map(Hollywood));
								For Player Variable(Event Player, TP, 3, 6, 1);
									If(Event Player.TP == 3);
										Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[7 - Event Player.IsInMap], 1.500 * ((
											5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
									Else If(Event Player.TP == 4);
										Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[9 - Event Player.IsInMap], 1.500 * ((
											5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
									Else;
										Create Effect(Event Player, Ring, Color(Red), Global.TeleporterPositions[11 - Event Player.IsInMap], 1.500 * ((
											5 - Event Player.TeleporterCD) / 5), Visible To Position and Radius);
									End;
									Event Player.TeleporterRingCD[Event Player.TP] = Last Created Entity;
								End;
							End;
							Play Effect(All Players(All Teams), Bad Pickup Effect, Color(Blue), Event Player, 1);
							Play Effect(All Players(All Teams), Buff Explosion Sound, Null, Event Player, 69);
						End;
						disabled Else;
						disabled Small Message(Event Player, Custom String("  hmm maybe reinhardts can use this"));
						disabled End;
					Else;
						Play Effect(All Players(All Teams), Bad Explosion, Color(Red), Event Player, 1);
						Play Effect(All Players(All Teams), Debuff Impact Sound, Null, Event Player, 69);
					End;
					Event Player.TP = Count Of(Global.TeleporterPositions);
					Small Message(Event Player, Custom String("  {0}s {1} CD", Round To Integer(Event Player.TeleporterCD, Up), Ability Icon String(
						Hero(Symmetra), Button(Ability 2))));
				End;
			End;
		End;
	}
}

rule("Destroy Teleporter Ring CD")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Event Player.TeleporterCD == 0;
	}

	actions
	{
		For Player Variable(Event Player, TP, 0, Count Of(Event Player.TeleporterRingCD), 1);
			Destroy Effect(Event Player.TeleporterRingCD[Event Player.TP]);
		End;
	}
}

rule("Leave Spawn")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Total Time Elapsed > 15;
		Global.RoundStart == True;
		Is Alive(Event Player) == True;
		Is In Spawn Room(Event Player) == True;
	}

	actions
	{
		Big Message(Event Player, Custom String("Leave Spawn! ({0}s)", Round To Integer(Event Player.LeaveSpawnTimer, Down)));
		Chase Player Variable At Rate(Event Player, LeaveSpawnTimer, 0, 1, None);
		If(!Event Player.IsInMap[1]);
			Create Effect(Event Player, Sphere, Color(Red), Is In Spawn Room(Event Player) && (Global.BubblePosition == 0 || Distance Between(
				Event Player, Global.BubblePosition) >= 12.400) ? Eye Position(Event Player) : Vector(0, -36, 0), 1, Position and Radius);
			Event Player.IsInMap[1] = True;
		End;
		Play Effect(Event Player, Explosion Sound, Color(Red), Event Player, 69);
		Set Healing Received(Event Player, 0);
		Wait Until(!Is In Spawn Room(Event Player) || (Global.BubblePosition != 0 && Distance Between(Event Player, Global.BubblePosition)
			< 12.400), Event Player.LeaveSpawnTimer);
		If(Is In Spawn Room(Event Player) && (Global.BubblePosition == 0 || Distance Between(Event Player, Global.BubblePosition)
			>= 12.400));
			Event Player.mercydeath = True;
			Kill(Event Player, Null);
			Wait(0.250, Ignore Condition);
			Event Player.mercydeath = False;
		End;
		Set Healing Received(Event Player, 100);
		Chase Player Variable At Rate(Event Player, LeaveSpawnTimer, Team Of(Event Player) == Team 1 ? 10 : 5, 0.200, None);
	}
}

rule("Tractor Beam visual")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
	}

	actions
	{
		If(Current Map == Map(Château Guillard) || Current Map == Map(Château Guillard Halloween));
			Global.TractorBeamPosition = Array(Vector(159.039, -4, 65.976), 6.900);
		Else If(Current Map == Map(Circuit royal));
			Global.TractorBeamPosition = Array(Vector(9, 4, 39), 6.900);
			disabled Else If(Current Map == Map(Hanamura) || Current Map == Map(Hanamura Winter));
		Else If(Current Map == Map(Hanamura Winter));
			Global.TractorBeamPosition = Array(Vector(-40.790, -5, -51.350), 6.900);
		Else If(Current Map == Map(Suravasa));
			Global.TractorBeamPosition = Array(Vector(-79.500, 0, 42), 3.690);
		End;
		If(Global.TractorBeamPosition != 0);
			Create Effect(All Players(Team 1), Light Shaft, Color(Aqua), Global.TractorBeamPosition[0], Global.TractorBeamPosition[1],
				Visible To);
			Create Effect(All Players(Team 2), Light Shaft, Color(Gray), Global.TractorBeamPosition[0], Global.TractorBeamPosition[1],
				Visible To Position and Radius);
			Create Effect(All Players(All Teams), Sphere, Color(Gray), Global.TractorBeamPosition[0] + Vector(0, 38, 0), 3.690, Visible To);
			Create Effect(All Players(All Teams), Sphere, Color(Lime Green), Global.TractorBeamPosition[0] + Vector(0, 41.500, 0), 3.369,
				Visible To);
			Create Effect(All Players(All Teams), Good Aura, Color(Aqua), Global.TractorBeamPosition[0] + Vector(0, 35.690, 0), 3.690,
				Visible To);
			For Global Variable(Loop, 0, 360, 22.500);
				Create Effect(All Players(All Teams), Sphere, Color(Gray), Global.TractorBeamPosition[0] + Vector(3.690 * Sine From Degrees(
					Global.Loop), 38.500, 3.690 * Cosine From Degrees(Global.Loop)), 3.690, Visible To);
			End;
		End;
	}
}

rule("Tractor Beam levitation")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Global.TractorBeamPosition != 0;
		Distance Between(Vector(X Component Of(Position Of(Event Player)), Y Component Of(Global.TractorBeamPosition[0]), Z Component Of(
			Position Of(Event Player))), Global.TractorBeamPosition[0]) <= Global.TractorBeamPosition[1];
		Y Component Of(Position Of(Event Player)) + 1 > Y Component Of(Global.TractorBeamPosition[0]);
	}

	actions
	{
		If(Team Of(Event Player) == Team 1);
			Start Accelerating(Event Player, Up, 100, 2.690, To World, Direction Rate and Max Speed);
			Small Message(Event Player, Custom String("  You've been caught in a tractor beam!!"));
			If(!Global.TractorBeamPosition[2]);
				Create Effect(All Players(All Teams), Energy Sound, Null, Global.TractorBeamPosition[0] + Vector(0, 35.690, 0), 99,
					Visible To Position and Radius);
				Global.TractorBeamPosition[2] = Last Created Entity;
			End;
			Wait Until(Distance Between(Vector(X Component Of(Position Of(Event Player)), Y Component Of(Global.TractorBeamPosition[0]),
				Z Component Of(Position Of(Event Player))), Global.TractorBeamPosition[0]) > Global.TractorBeamPosition[1], 9999);
			Stop Accelerating(Event Player);
			If(Distance Between(Vector(X Component Of(Position Of(Farthest Player From(Event Player, Team 1))), Y Component Of(
				Global.TractorBeamPosition[0]), Z Component Of(Position Of(Farthest Player From(Event Player, Team 1)))),
				Global.TractorBeamPosition[0]) > Global.TractorBeamPosition[1]);
				Destroy Effect(Global.TractorBeamPosition[2]);
				Global.TractorBeamPosition[2] = 0;
			End;
		Else;
			Small Message(Event Player, Custom String("  hmm maybe reinhardts can use this"));
			Wait(5, Ignore Condition);
		End;
	}
}

rule("CTF Draw HUD")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		"(Current Game Mode == Game Mode(Capture the Flag) || Current Game Mode == Game Mode(Skirmish)) != (Current Game Mode == Game Mode(\r\n			Clash));"
		(Current Game Mode == Game Mode(Capture the Flag)) != (Current Game Mode == Game Mode(Skirmish));
	}

	actions
	{
		Wait(6.969, Ignore Condition);
		Disable Game Mode HUD(All Players(All Teams));
		Disable Game Mode In-World UI(All Players(All Teams));
		Create HUD Text(All Players(Team 1), Custom String("{0} - {1}{2}", Custom String("{0}{1}", Hero Icon String(Hero(Reinhardt)),
			Global.Score[0]), Global.Score[1], Hero Icon String(Hero(Mercy))), Null, Null, Top, -1, Color(Purple), Null, Null,
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Custom String("{0} - {1}{2}", Custom String("{0}{1}", Hero Icon String(Hero(Mercy)),
			Global.Score[1]), Global.Score[0], Hero Icon String(Hero(Reinhardt))), Null, Null, Top, -1, Color(Purple), Null, Null,
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(All Teams), Null, Null, Custom String("\n\r\n"), Top, 1, Null, Null, Null, Visible To and String,
			Visible Never);
		Create HUD Text(All Players(All Teams), Null, Null, Custom String("\nW"), Top, -2, Null, Null, Null, Visible To and String,
			Default Visibility);
		Create HUD Text(All Players(All Teams), Null, Null, Custom String("{0}{1}", Round To Integer(Match Time, Down),
			Match Time < 10 ? Custom String(".{0}", Round To Integer((Match Time - Round To Integer(Match Time, Down)) * 10, Down))
			: Empty Array), Top, 0.690, Null, Null, Color(White), Visible To and String, Default Visibility);
	}
}

