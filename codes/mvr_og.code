rule("Switch Players (old reliable)")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Is Match Complete == True;
		Number Of Players(All Teams) < 12;
	}

	actions
	{
		Set Slow Motion(100);
		Wait(25.750, Abort When False);
		Global.CurrentSeekers = Filtered Array(All Players(Team 1), Current Array Element != 0);
		Global.NextSeekers = Array Slice(Randomized Array(Global.NextSeekers), 0, 2);
		If(Count Of(Global.NextSeekers) < 2);
			Modify Global Variable(NextSeekers, Append To Array, Array Slice(Randomized Array(All Players(Team 2)), 0, 2 - Count Of(
				Global.NextSeekers)));
		End;
		If(Number Of Players(Team 1) == 2);
			If(Team Of(Global.NextSeekers[0]) != Team 1);
				Move Player to Team(Global.CurrentSeekers[0], Team 2, -1);
				Move Player to Team(Global.NextSeekers[0], Team 1, -1);
			End;
			If(Team Of(Global.NextSeekers[1]) != Team 1);
				Move Player to Team(Global.CurrentSeekers[1], Team 2, -1);
				Move Player to Team(Global.NextSeekers[1], Team 1, -1);
			End;
		Else;
			If(Team Of(Global.NextSeekers[0]) != Team 1);
				Move Player to Team(Global.NextSeekers[0], Team 1, -1);
				Move Player to Team(Global.CurrentSeekers[0], Team 2, -1);
			End;
			If(Team Of(Global.NextSeekers[1]) != Team 1);
				Move Player to Team(Global.NextSeekers[1], Team 1, -1);
				Move Player to Team(Global.CurrentSeekers[1], Team 2, -1);
			End;
		End;
		Wait(0.250, Ignore Condition);
		Restart Match;
	}
}

rule("Check is Owner Afk only moving 1 direction V2")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		(Throttle Of(Host Player) != Global.IsOwnerAfk[5]) != (Is Button Held(Host Player, Button(Primary Fire)) != Global.IsOwnerAfk[6]);
		disabled Throttle Of(Host Player) != Global.IsOwnerAfk[5];
		Global.IsOwnerAfk[0] != True;
	}

	actions
	{
		Wait(15, Ignore Condition);
		Global.IsOwnerAfk[5] = Throttle Of(Host Player);
		Global.IsOwnerAfk[6] = Is Button Held(Host Player, Button(Primary Fire));
		Wait(150, Restart When True);
		If(!Global.IsOwnerAfk[1]);
			If(Current Game Mode == Game Mode(Elimination));
				Global.IsOwnerAfk[4] = Empty Array;
			Else;
				Global.IsOwnerAfk[4] = Custom String(
					"                                                                                                                             {0}",
					Custom String("                                                                           "));
			End;
			Create HUD Text(Global.IsOwnerAfk[0] && Match Time > 145 ? All Players(Team 1) : Null, Null, Custom String(
				"Vote to Kick AFK Owner: {0}\n({1}+{2}", Host Player, Input Binding String(Button(Primary Fire)), Custom String(
				"{0}+{1} to add/remove)\nVotes Required: {2}", Input Binding String(Button(Secondary Fire)), Input Binding String(Button(
				Melee)), Custom String("{0}          {1}", Global.IsOwnerAfk[2], Global.CurrentSeekers[2]))), Custom String(
				"Current Votes: {0} {2}\nVote Time Remaining: {1}s", Global.IsOwnerAfk[3], Round To Integer(Match Time - 145, Up),
				Local Player.VotedKick ? Icon String(Checkmark) : Icon String(X)), Left, 4.500, Null, Color(Purple), Color(Red),
				Visible To and String, Default Visibility);
			Create HUD Text(Global.IsOwnerAfk[0] && Match Time > 145 ? All Players(Team 2) : Null, Null, Custom String(
				"{0}Vote to Kick AFK Owner: {1}\n{0}({2}", Global.CurrentSeekers[2], Host Player, Custom String("{0}+{1}+{2}",
				Input Binding String(Button(Primary Fire)), Input Binding String(Button(Secondary Fire)), Custom String(
				"{0} to add/remove)\n{1}Votes Required: {2}", Input Binding String(Button(Melee)), Global.CurrentSeekers[2],
				Global.IsOwnerAfk[2]))), Custom String("{0}Current Votes: {1}{2}", Global.IsOwnerAfk[4], Global.IsOwnerAfk[3], Custom String(
				" {0}\n{1}Vote Time Remaining: {2}s", Local Player.VotedKick ? Icon String(Checkmark) : Icon String(X), Global.IsOwnerAfk[4],
				Round To Integer(Match Time - 145, Up))), Right, 4.500, Null, Color(Purple), Color(Red), Visible To and String,
				Default Visibility);
			Create HUD Text(Host Player == Local Player && Global.IsOwnerAfk[0] ? Local Player : Null, Custom String("!!!AFK WARNING!!!",
				Input Binding String(Button(Primary Fire))), Null, Null, Top, 0, Color(White), Null, Null, Visible To, Default Visibility);
			Create HUD Text(Host Player == Local Player && Global.IsOwnerAfk[0] ? Local Player : Null, Null, Null, Custom String(
				"Hit Primary Fire to prevent\n    VoteKick next round!!"), Top, 0, Null, Null, Color(White), Visible To, Default Visibility);
			Global.IsOwnerAfk[1] = True;
		End;
		Global.IsOwnerAfk[0] = True;
		Global.IsOwnerAfk[2] = Round To Integer(Number Of Players(All Teams) * 0.500, Down);
		Global.IsOwnerAfk[6] = Is Button Held(Host Player, Button(Primary Fire));
		Wait Until(Is Button Held(Host Player, Button(Primary Fire)) != Global.IsOwnerAfk[6], 9999);
		Global.IsOwnerAfk[0] = False;
	}
}

rule("Player Vote to Kick AFK Owner")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Global.IsOwnerAfk[0] == True;
		(Is Button Held(Event Player, Button(Primary Fire)) && Is Button Held(Event Player, Button(Secondary Fire)) && Is Button Held(
			Event Player, Button(Melee))) == True;
		Match Time > 145;
	}

	actions
	{
		If(Event Player.VotedKick);
			Global.IsOwnerAfk[3] -= 1;
			Event Player.VotedKick = False;
		Else;
			Global.IsOwnerAfk[3] += 1;
			Event Player.VotedKick = True;
		End;
		Wait(1, Ignore Condition);
	}
}

rule("Kick Afk Owner")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Global.IsOwnerAfk[0] == True;
		Global.IsOwnerAfk[3] >= Global.IsOwnerAfk[2];
		Global.IsOwnerAfk[2] > 0;
	}

	actions
	{
		Remove Player(Host Player);
	}
}

rule("Player Left Reset Variables")
{
	event
	{
		Player Left Match;
		All;
		All;
	}

	actions
	{
		If(Array Contains(Global.NextSeekers, Event Player));
			Modify Global Variable(NextSeekers, Remove From Array By Value, Event Player);
		End;
		If(Event Player.VotedKick);
			Global.IsOwnerAfk[3] -= 1;
			Event Player.VotedKick = False;
		End;
		If(Event Player == Host Player);
			All Players(All Teams).VotedKick = False;
			Global.IsOwnerAfk[3] = 0;
			Global.IsOwnerAfk[0] = False;
		End;
		If(Team Of(Event Player) == Team 1);
			Global.CombineBackStabReinResurrect[1] = True;
		Else;
			Global.RezzedMercy = Filtered Array(All Players(Team 2), Current Array Element.RezzedMercy == Event Player);
			Set Ability Cooldown(Global.RezzedMercy, Button(Ability 2), 0);
			Set Ability Cooldown(Global.RezzedMercy, Button(Secondary Fire), 0);
			Small Message(Global.RezzedMercy, Custom String("  Refunded {0} Resurrect", Ability Icon String(Hero(Mercy), Button(Ability 2))));
		End;
	}
}

