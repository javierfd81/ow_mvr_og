rule("Heart beat sound at 30 seconds remaining")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Match Time <= 30;
		Match Time >= 0.740;
		(Global.RoundStart || !Is True For Any(Array(Is In Setup, Is Assembling Heroes, Is Between Rounds, !(
			Current Game Mode == Game Mode(Elimination)), Is Match Complete), Current Array Element)) == True;
	}

	actions
	{
		Play Effect(Event Player, Explosion Sound, Null, Event Player, 42 - Match Time);
		Wait(0.240, Ignore Condition);
		Play Effect(Event Player, Debuff Impact Sound, Null, Event Player, 36 - Match Time);
		Wait(0.500 + Match Time / 30, Ignore Condition);
		Loop If Condition Is True;
	}
}

