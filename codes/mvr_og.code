			Global.FencePosition = Array(Vector(0, 0, 0), 0);
			disabled Else If(Current Map == Map(Runasapi));
		Else If(Current Map == Map(Samoa));
		Else If(Current Map == Map(Shambali Monastery));
			disabled Else If(Current Map == Map(Suravasa));
		Else If(Current Map == Map(Temple of Anubis) && Current Game Mode == Game Mode(Team Deathmatch));
			Global.TDMSpawnPositions = Array(Vector(16.750, 4.480, 112.780), Vector(-44.150, 9.560, 23.190));
		Else If(Current Map == Map(Temple of Anubis));
			Global.TDMSpawnPositions = Array(Vector(-44.500, 10.500, 22.500), Vector(-24, -2, -18));
			Global.FencePosition = Array(Vector(-145, 1, 47), 90);
		Else If(Current Map == Map(Volskaya Industries) && Current Game Mode == Game Mode(Team Deathmatch));
			Global.TDMSpawnPositions = Array(Vector(-127, -1.980, 49), Vector(28.510, -4.050, 78.250));
		Else If(Current Map == Map(Volskaya Industries));
			Global.TDMSpawnPositions = Array(Vector(-13.889, -4, 112.570), Vector(-11.400, -6.980, 1.700));
			Global.FencePosition = Array(Vector(-19.560, -3, 207), 0);
		Else If(Current Map == Map(Watchpoint: Gibraltar));
		Else;
			Create HUD Text(All Players(All Teams), Custom String("This Map is Not Supported!!"), Null, Null, Top, 0.695, Color(White), Null,
				Null, Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Custom String("Please Turn Off This Map!"), Null, Null, Top, 0.700, Color(White), Null,
				Null, Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Custom String("Game Will Restart in {0}s", Round To Integer(Global.ExpectedGamemode, Up)),
				Null, Null, Top, 0.720, Color(White), Null, Null, Visible To and String, Default Visibility);
			Global.ExpectedGamemode = 60;
			Chase Global Variable Over Time(ExpectedGamemode, 0, 60, None);
			Wait Until(Global.ExpectedGamemode == 0, 69);
			Restart Match;
		End;
	}
}

rule("Skirmish Handler + Set Spawns - New Spawn Points")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		"(Current Game Mode == Game Mode(Skirmish)) != (Current Game Mode == Game Mode(Clash));"
		Current Game Mode == Game Mode(Skirmish);
	}

	actions
