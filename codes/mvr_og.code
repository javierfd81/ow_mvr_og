rule("Paris piano mercy bullet speed")
{
	event
	{
		Ongoing - Each Player;
		Team 2;
		All;
	}

	conditions
	{
		Vertical Facing Angle Of(Event Player) > 38;
		Is True For Any(Array(Current Map == Map(Paris) && (Distance Between(Event Player, Vector(-40.726, 12.500, 33.329))
			< 3.690 || Distance Between(Event Player, Vector(-84.776, 13.510, -107.514)) < 3.690), Current Map == Map(Circuit royal)
			&& Distance Between(Event Player, Vector(-102.644, 8.500, -41.489)) < 3.690), Current Array Element) == True;
	}

	actions
	{
		Set Projectile Speed(Event Player, 500);
		If(Current Map == Map(Circuit royal));
			Wait Until(Vertical Facing Angle Of(Event Player) <= 38 || Distance Between(Event Player, Vector(-102.644, 8.500, -41.489))
				>= 3.690, 9999);
		Else;
			Wait Until(Vertical Facing Angle Of(Event Player) <= 38 || (Distance Between(Event Player, Vector(-40.726, 12.500, 33.329))
				>= 3.690 && Distance Between(Event Player, Vector(-84.776, 13.510, -107.514)) >= 3.690), 9999);
		End;
		Set Projectile Speed(Event Player, 100);
	}
}

