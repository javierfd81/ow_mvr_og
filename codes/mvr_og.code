rule("DisplayTips SUBROUTINE")
{
	event
	{
		Subroutine;
		DisplayTips;
	}

	actions
	{
		Wait(1, Ignore Condition);
		For Global Variable(Loop, 0, 4, 1);
			Small Message(All Players(Team 1), Global.Tips[0][Global.Loop]);
			Small Message(All Players(Team 2), Global.Tips[1][Global.Loop]);
			Wait(2, Ignore Condition);
		End;
		Start Rule(ReinTips, Restart Rule);
		If(Global.TeleporterPositions != 0 && !Global.SkirmishSpawns);
			Small Message(All Players(Team 2), Custom String("  Jump While Within Blue Circles to {0} Teleport ({1}s CD)", Ability Icon String(
				Hero(Symmetra), Button(Ability 2)), Global.TeleporterCD));
			Wait(2, Ignore Condition);
		End;
		Small Message(All Players(Team 2), Custom String("  {0} Match Voice Chat is Open! {1}", Hero Icon String(Hero(Mercy)),
			Hero Icon String(Hero(Reinhardt))));
		Wait(2, Ignore Condition);
		Small Message(All Players(Team 2), Custom String("  (press L to open lobby, then click on the map)"));
		Small Message(All Players(Team 2), Custom String("  Check Description for more information"));
		If(Team Of(Host Player) == Team 2);
			Wait(2, Ignore Condition);
			Small Message(Host Player, Custom String("  Crouch Interact to show/hide server load stats"));
		End;
	}
}

rule("ReinTips SUBROUTINE")
{
	event
	{
		Subroutine;
		ReinTips;
	}

	actions
	{
		If(Global.TeleporterPositions != 0);
			Small Message(All Players(Team 1), Custom String("  Jump While Within Blue Circles to {0} Teleport", Ability Icon String(Hero(
				Symmetra), Button(Ability 2))));
			Wait(2, Ignore Condition);
		End;
		If(Global.JumpPadPosition != 0);
			Small Message(All Players(Team 1), Custom String("  Jump While Within Green Circles to use {0} Jump Pad", Ability Icon String(Hero(
				Baptiste), Button(Crouch))));
			Wait(2, Ignore Condition);
		End;
		Small Message(All Players(Team 1), Custom String("  {1} Match Voice Chat is Open! {0}", Hero Icon String(Hero(Mercy)),
			Hero Icon String(Hero(Reinhardt))));
		Wait(1.690, Ignore Condition);
		Small Message(All Players(Team 1), Custom String("  (press L to open lobby, then click on the map)"));
		Small Message(All Players(Team 1), Custom String("  Check Description for more information"));
		If(Team Of(Host Player) == Team 1);
			Wait(2, Ignore Condition);
			Small Message(Host Player, Custom String("  Crouch Interact to show/hide server load stats"));
		End;
	}
}

