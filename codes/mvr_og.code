			Global.D[8], 1, Team 2, Off), Players Within Radius(Global.D[9], 1, Team 2, Off)))))))))), Global.SpawnNoClip)
			!= Remove From Array(Global.SpawnNoClip, Append To Array(Players Within Radius(Global.D[0], 1, Team 2, Off), Append To Array(
			Players Within Radius(Global.D[1], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[2], 1, Team 2, Off),
			Append To Array(Players Within Radius(Global.D[3], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[4], 1,
			Team 2, Off), Append To Array(Players Within Radius(Global.D[5], 1, Team 2, Off), Append To Array(Players Within Radius(
			Global.D[6], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[7], 1, Team 2, Off), Append To Array(
			Players Within Radius(Global.D[8], 1, Team 2, Off), Players Within Radius(Global.D[9], 1, Team 2, Off)))))))))));
	}

	actions
	{
		Global.SpawnNoClip = Append To Array(Players Within Radius(Global.D[0], 1, Team 2, Off), Append To Array(Players Within Radius(
			Global.D[1], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[2], 1, Team 2, Off), Append To Array(
			Players Within Radius(Global.D[3], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[4], 1, Team 2, Off),
			Append To Array(Players Within Radius(Global.D[5], 1, Team 2, Off), Append To Array(Players Within Radius(Global.D[6], 1,
			Team 2, Off), Append To Array(Players Within Radius(Global.D[7], 1, Team 2, Off), Append To Array(Players Within Radius(
			Global.D[8], 1, Team 2, Off), Players Within Radius(Global.D[9], 1, Team 2, Off))))))))));
		Disable Movement Collision With Environment(Global.SpawnNoClip, False);
		Enable Movement Collision With Environment(Remove From Array(All Players(Team 2), Global.SpawnNoClip));
	}
