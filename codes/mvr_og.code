rule("Global Startup")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		Disable Inspector Recording;
		Create HUD Text(All Living Players(All Teams), Null, Global.ShowServerLoad && Local Player == Host Player ? Custom String(
			"C{0}, A{1}, P{2}", Server Load, Server Load Average, Server Load Peak) : Empty Array, Null, Left, 4.100, Null, Color(White),
			Null, Visible To and String, Default Visibility);
		disabled Create HUD Text(Host Player == Local Player && Global.ShowServerLoad ? Local Player : Null, Server Load, Server Load Average,
			Server Load Peak, Left, 4.100, Color(White), Color(White), Color(White), Visible To and String, Default Visibility);
		Global.MaxGACount = Workshop Setting Integer(Custom String("Mercy Settings"), Custom String("GA count"), 3, 1, 3, 0);
		Global.NextSeekers = Empty Array;
		Global.CurrentSeekers[0] = Custom String("");
		Global.CurrentSeekers[1] = Custom String("");
		Global.CurrentSeekers[2] = Empty Array;
		Global.IsOwnerAfk[5] = Vector(0, 1, 0);
		Global.Tips = Array(Array(Custom String("  Jump Midair to {0} Double Jump (touch ground to reset)", Ability Icon String(Hero(
			Winston), Button(Ability 1))), Custom String("  {0} Quick Melee to {1} Super Jump (45s CD)", Ability Icon String(Hero(
			Reinhardt), Button(Melee)), Ability Icon String(Hero(Baptiste), Button(Crouch))), Custom String(
			"  Press and Hold {0} Shatter to Sacrifice Health for % ult charge", Ability Icon String(Hero(Reinhardt), Button(Ultimate))),
			Custom String("  Crouch while using {0} Shatter to Ground Pound", Ability Icon String(Hero(Reinhardt), Button(Ultimate)))),
			Array(Custom String("  Interact to Toggle Perspective"), Custom String("  Crouch + Reload to Lay Down"), Custom String(
			"  {0} Melee reins to boop and reduce rez CD by 3s", Ability Icon String(Hero(Mercy), Button(Melee))), Custom String(
			"  Hit Rez While {0} Rezzing To {1} Cancel Early", Ability Icon String(Hero(Mercy), Button(Ability 2)), Icon String(No))));
		Abort If(Current Game Mode != Game Mode(Elimination));
		Wait Until(Is Assembling Heroes, 9999);
		Global.NextSeekers = Empty Array;
		Global.CurrentSeekers[0] = Custom String("");
		Global.CurrentSeekers[1] = Custom String("");
		Global.CurrentSeekers[2] = Empty Array;
	}
}

rule("Disable Team Voice")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	actions
	{
		Disable Voice Chat(Event Player, True, False, False);
	}
}

disabled rule("'Mercy Invis BOOP'")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Current Game Mode == Game Mode(Elimination);
	}

	actions
	{
		Create HUD Text(Event Player, Null, Custom String("5 Mercy Boops = Mercy Ult Invis"), Null, Right, 0, Color(White), Color(White),
			Color(White), None, Default Visibility);
	}
}

disabled rule("=========================================================CAMERA=============================================================")
{
	event
	{
		Ongoing - Global;
	}
}

rule("perspective toggle")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Interact)) == True;
	}

	actions
	{
		Event Player.perspectivetoggle = !Event Player.perspectivetoggle;
		If(Event Player.perspectivetoggle == True);
			Start Camera(Event Player, Ray Cast Hit Position(Eye Position(Event Player), Eye Position(Event Player) + World Vector Of(Vector(0,
				0.400, 0.300), Event Player, Rotation) + Facing Direction Of(Event Player) * -2.500, Null, Event Player, False),
				Event Player + Facing Direction Of(Event Player) * 1000, 40);
		Else;
			Stop Camera(Event Player);
		End;
	}
}

disabled rule("=====================================================MERCY POWER UPS============================================================")
{
	event
	{
		Ongoing - Global;
	}
}

rule("Mercy Activate Invis (Ultimate)")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Event Player.MercyBoopToInvis >= 5;
		Is Button Held(Event Player, Button(Ultimate)) == True;
		Is Alive(Event Player) == True;
		Is Dead(Event Player) != True;
	}

	actions
	{
		Set Invisible(Event Player, Enemies);
		Big Message(Event Player, Custom String("You're Invisible"));
		Create Icon(All Players(Team Of(Event Player)), Event Player, Arrow: Down, Visible To and Position, Color(White), True);
		Event Player.MercyInvis = Last Created Entity;
		Event Player.MercyBoopToInvis = 0;
		Wait(6, Ignore Condition);
		Destroy Icon(Event Player.MercyInvis);
		Set Invisible(Event Player, None);
		Big Message(Event Player, Custom String("Now Visible"));
	}
}

rule("Mercy Boop To Invis Setup")
{
	event
	{
		Player Dealt Knockback;
		All;
		Mercy;
	}

	conditions
	{
		Workshop Setting Toggle(Custom String("Mercy Settings"), Custom String("Mercy Boop To Earn Invis"), False, 0) == True;
	}

	actions
	{
		Event Player.MercyBoopToInvis = Event Player.MercyBoopToInvis + 1;
		Skip If(Event Player.MercyBoopToInvis >= 5, 1);
		Small Message(Event Player, Custom String("  {0} boops", Event Player.MercyBoopToInvis));
		If(Event Player.MercyBoopToInvis >= 5);
			Small Message(Event Player, Custom String("  Invis Ready, Ult to Invis"));
		End;
	}
}

rule("Mercy burn when hit by firestrike")
{
	event
	{
		Player Died;
		Team 2;
		All;
	}

	conditions
	{
		Is Game In Progress == True;
		Is Using Ability 2(Attacker) == True;
	}

	actions
	{
		Set Status(Event Player, Attacker, Burning, 4);
	}
}

rule("PlayerVariableSetter SUBROUTINE")
{
	event
	{
		Subroutine;
		PlayerVariableSetter;
	}

	actions
	{
		If(!Global.ChargeOnlyMap);
			Set Ability Cooldown(All Players(Team 2), Button(Ability 2), 0);
			Set Ability Cooldown(All Players(Team 2), Button(Secondary Fire), 0);
			All Players(Team 2).MercyDiedRezCD = False;
		End;
		All Players(All Teams).IsInMap = True;
		All Players(All Teams).KnockedDown = False;
		All Players(Team 1).ReinFlyCoolDown = 0;
		Global.CombineBackStabReinResurrect[1] = False;
		Set Healing Received(All Players(Team 1), 0);
		Set Healing Received(All Players(Team 2), 100);
	}
}

rule("Mercy reset rez cd for each round")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode == Game Mode(Elimination);
		Is In Setup == True;
	}

	actions
	{
		Wait(2, Ignore Condition);
		If(!Global.ChargeOnlyMap);
			Set Ability 2 Enabled(Players On Hero(Hero(Reinhardt), All Teams), True);
			Set Primary Fire Enabled(Players On Hero(Hero(Reinhardt), All Teams), True);
			Set Ability 1 Enabled(All Players(Team 2), True);
		End;
		Call Subroutine(PlayerVariableSetter);
	}
}

rule("Mercy: rez cancel")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		(Is Button Held(Event Player, Button(Ability 2)) || Is Button Held(Event Player, Button(Secondary Fire))) == True;
	}

	actions
	{
		If(Event Player.rezstop);
			Event Player.rezstop = False;
			Cancel Primary Action(Event Player);
			Wait(0.250, Ignore Condition);
			Set Ability Cooldown(Event Player, Button(Ability 2), 0);
			Set Ability Cooldown(Event Player, Button(Secondary Fire), 0);
		End;
	}
}

rule("Mercy Used Rez")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Using Ability 2(Event Player) == True;
	}

	actions
	{
		Wait(0.400, Ignore Condition);
		Event Player.rezstop = True;
		Wait Until(!Is Using Ability 2(Event Player), 3);
		If(Ability Cooldown(Event Player, Button(Ability 2)) == Ability Cooldown(Event Player, Button(Secondary Fire)));
			Event Player.rezstop = False;
		End;
		If(Event Player.rezstop);
			Event Player.rezstop = False;
			Set Ability Cooldown(Event Player, Button(Ability 2), Global.MercyRezScalar);
			Set Ability Cooldown(Event Player, Button(Secondary Fire), Global.MercyRezScalar);
			Event Player.RezzedMercy = Global.RezzedMercy;
			If(Ability Cooldown(Event Player, Button(Ability 2)) > 0);
				Wait Until(Ability Cooldown(Event Player, Button(Ability 2)) <= 20, Global.MercyRezScalar);
			Else;
				Wait Until(Ability Cooldown(Event Player, Button(Secondary Fire)) <= 20, Global.MercyRezScalar);
			End;
			Event Player.RezzedMercy = Null;
		End;
	}
}

rule("Set rezzed mercy")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Alive(Event Player) == True;
	}

	actions
	{
		Global.RezzedMercy = Event Player;
	}
}

rule("Mercy GA Recharge + Reenable GA")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		((!Global.ExperimentalChargeOnlyMap && Event Player.MercyGACount < Global.MaxGACount) || (
			Global.ExperimentalChargeOnlyMap && Event Player.MercyGACount < 1)) == True;
		(Is On Ground(Event Player) || Is Dead(Event Player)) == True;
	}

	actions
	{
		disabled Chase Player Variable Over Time(Event Player, MercyGACount, 3, Workshop Setting Real(Custom String("Mercy Settings"),
			Custom String("GA Recharge Rate"), 1, 0, 100, 6), Destination and Duration);
		If(Global.ExperimentalChargeOnlyMap);
			If(Is Dead(Event Player));
				Stop Chasing Player Variable(Event Player, MercyGACount);
				Event Player.MercyGACount = 1;
				Set Ability 1 Enabled(Event Player, True);
				Abort;
			End;
			Chase Player Variable At Rate(Event Player, MercyGACount, 1, 1, None);
			Wait Until(!Is On Ground(Event Player), 1 - Event Player.MercyGACount);
			Stop Chasing Player Variable(Event Player, MercyGACount);
			If(!Is On Ground(Event Player));
				Chase Player Variable At Rate(Event Player, MercyGACount, 0.999, 0.250, Destination and Rate);
				Abort;
			End;
		Else;
			Event Player.MercyGACount = Global.MaxGACount;
		End;
		If(Is Alive(Event Player));
			Play Effect(Event Player, Buff Impact Sound, Null, Event Player, 16);
		End;
		Set Ability 1 Enabled(Event Player, True);
	}
}

rule("GA use")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Event Player.MercyGACount >= 1;
		Ability Cooldown(Event Player, Button(Ability 1)) != 0;
		Is On Ground(Event Player) == False;
	}

	actions
	{
		Event Player.MercyGACount = Event Player.MercyGACount - 1;
		If(Event Player.MercyGACount == 0);
			Set Ability 1 Enabled(Event Player, False);
			If(!Event Player.HasNoGAs);
				If(Global.ExperimentalChargeOnlyMap);
					disabled Create Effect(All Players(All Teams), Good Aura, Color(Orange), Event Player.MercyGACount < 1 ? Eye Position(Event Player)
						- Vector(Sine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175, Is On Ground(Event Player) ? 0 : (Is Button Held(
						Event Player, Button(Jump)) ? -0.200 : -0.320), Cosine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175)
						: Vector(0, -36, 0), (1 - Event Player.MercyGACount) / 20, Visible To Position and Radius);
					Create Effect(All Players(All Teams), Good Aura, Color(Orange), Event Player.MercyGACount < 1 ? Eye Position(Event Player)
						- Vector(Sine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175, Is On Ground(Event Player) ? 0 : (Is Button Held(
						Event Player, Button(Jump)) ? -0.200 : -0.320), Cosine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175)
						: Vector(0, -36, 0), 0.010, Visible To Position and Radius);
				Else;
					Create Effect(All Players(All Teams), Good Aura, Color(Orange), Event Player.MercyGACount < 1 ? Eye Position(Event Player)
						- Vector(Sine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175, Is Button Held(Event Player, Button(Jump))
						? -0.200 : -0.320, Cosine From Degrees(Horizontal Facing Angle Of(Event Player)) * 0.175) : Vector(0, -36, 0), 0.010,
						Visible To Position and Radius);
				End;
				Event Player.HasNoGAs = True;
			End;
		End;
	}
}

rule("Mercy No Envir Death")
{
	event
	{
		Player Died;
		Team 2;
		All;
	}

	conditions
	{
		Attacker == Event Player;
		Workshop Setting Toggle(Custom String("Mercy Settings"), Custom String("Respawn On Map"), False, 0) == True;
		Is On Ground(Event Player) == False;
	}

	actions
	{
		If(!Event Player.mercydeath);
			Event Player.mercydeath = True;
			Wait(3, Ignore Condition);
			Skip If(Current Game Mode != Game Mode(Elimination) && !Global.RoundStart, 8);
			Teleport(Event Player, Nearest Walkable Position(Event Player));
			Resurrect(Event Player);
			Wait(0.100, Ignore Condition);
			Kill(Event Player, Null);
			Wait(0.250, Ignore Condition);
			If(Array Contains(Array(Map(King's Row Winter), Map(Rialto)), Current Map) || (Current Map == Map(Dorado) && Distance Between(
				Vector(36, 3, 21), Event Player) <= 17 && Current Game Mode == Game Mode(Team Deathmatch)) || (Current Map == Map(
				Eichenwalde Halloween) && X Component Of(Position Of(Event Player)) < 36));
				Teleport(Event Player, Global.TDMSpawnPositions[1] + Vector(Random Real(-3.069, 3.069), 0.069, Random Real(-3.069, 3.069)));
				Event Player.IsInMap = True;
			Else If(Current Map == Map(Circuit royal) && Z Component Of(Position Of(Event Player)) > 45);
				Teleport(Event Player, Vector(80, 18, 50));
			Else If(Current Map == Map(Hanamura) && Current Game Mode == Game Mode(Skirmish));
				Event Player.IsInMap = True;
			End;
			Event Player.mercydeath = False;
		End;
	}
}

rule("Mercy: record dead mercy for rez cd")
{
	event
	{
		Player Died;
		All;
		Mercy;
	}

	actions
	{
		Event Player.MercyDiedRezCD = True;
	}
}

rule("Mercy: change mercy rez cd when they are ressed")
{
	event
	{
		Ongoing - Each Player;
		All;
		Mercy;
	}

	conditions
	{
		Is Alive(Event Player) == True;
		Event Player.MercyDiedRezCD == True;
		Event Player.mercydeath != True;
	}

	actions
	{
		Event Player.MercyDiedRezCD = False;
		If(Ability Cooldown(Event Player, Button(Ability 2)) < 20);
			Set Ability Cooldown(Event Player, Button(Ability 2), 20);
		End;
		If(Ability Cooldown(Event Player, Button(Secondary Fire)) < 20);
			Set Ability Cooldown(Event Player, Button(Secondary Fire), 20);
		End;
	}
}

rule("Global HUD text spacing")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		If(Current Game Mode == Game Mode(Elimination));
			Create HUD Text(All Players(All Teams), Null, Null, Custom String("\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"), Top, 1, Null, Null,
				Null, Visible To, Default Visibility);
		Else If(Current Game Mode == Game Mode(Team Deathmatch));
			Create HUD Text(All Players(All Teams), Null, Null, Custom String("\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"), Top, 1, Null, Null, Null,
				Visible To, Default Visibility);
		Else;
			Create HUD Text(All Players(All Teams), Null, Custom String(" "), Custom String("\n\n\n\n\n"), Top, 1, Null, Null, Null,
				Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Null, Custom String(" "), Custom String("\n\n\n\n\n"), Top, 1, Null, Null, Null,
				Visible To, Default Visibility);
		End;
		Create HUD Text(All Players(Team 1), Null, Null, Custom String("\n\n\n\n\n\n\n\n\n"), Top, 1.690, Null, Null, Null, Visible To,
			Default Visibility);
	}
}

