rule("Mercy Rez Balancing with Map Size")
{
	event
	{
		Ongoing - Global;
	}

	actions
	{
		"Big Maps"
		If(Array Contains(Array(Map(Hanamura Winter), Map(Hollywood), Map(Hollywood Halloween), Map(Ilios Lighthouse), Map(Ilios Ruins),
			Map(Ilios Well), Map(Lijiang Control Center), Map(Lijiang Control Center Lunar New Year), Map(Nepal Sanctum), Map(Petra), Map(
			Runasapi)), Current Map));
			Global.MercyRezScalar = 80;
			Global.RevealTime = 4;
		"Extra Big Maps"
		Else If(Array Contains(Array(Map(New Junk City), Map(Suravasa)), Current Map));
			Global.MercyRezScalar = 90;
			Global.RevealTime = 4;
		"Small Maps"
		Else If(Array Contains(Array(Map(Black Forest), Map(Black Forest Winter), Map(Busan Downtown Lunar New Year), Map(
				Busan Sanctuary Lunar New Year), Map(Castillo), Map(Colosseo), Map(Eichenwalde), Map(Havana), Map(Hollywood), Map(Necropolis),
				Map(Rialto), Map(Workshop Chamber)), Current Map) || (Current Game Mode == Game Mode(Skirmish) && Array Contains(Array(Map(
				Dorado), Map(Temple of Anubis), Map(Volskaya Industries)), Current Map)));
			Global.MercyRezScalar = 65;
			Global.RevealTime = 2;
		"Average Maps"
		Else;
			Global.MercyRezScalar = 75;
			Global.RevealTime = 3;
		End;
	}
}

