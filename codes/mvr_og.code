rule("TDM Setup")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
	}

	actions
	{
		Global.Score = Array(0, 0, True);
		Start Rule(SpawnSetter, Do Nothing);
		Wait(3.690, Ignore Condition);
		If(Current Game Mode == Game Mode(Skirmish));
			Set Respawn Max Time(All Players(All Teams), 999);
		End;
		Disable Built-In Game Mode Announcer;
		Disable Built-In Game Mode Respawning(All Players(All Teams));
		Enable Death Spectate Target HUD(All Players(All Teams));
		Disable Built-In Game Mode Scoring;
		Disable Built-In Game Mode Completion;
		Global.NumMercysDead = -1;
		If(Count Of(All Players(Team 1)) == 0);
			Create Dummy Bot(Hero(Reinhardt), Team 1, -1, Global.TDMSpawnPositions[0], Vector(0, 0, 0));
			Start Forcing Dummy Bot Name(Last Created Entity, Custom String(
				"                                                                               check description for info + discord server link"));
		End;
		If(Count Of(All Players(Team 2)) == 0);
			Create Dummy Bot(Hero(Mercy), Team 2, -1, Global.TDMSpawnPositions[1], Vector(0, 0, 0));
			Start Forcing Dummy Bot Name(Last Created Entity, Custom String("check description for info + discord server link"));
		End;
		Global.CurrentSeekers[2] = Custom String("               {0}{0}", Custom String(
			"                                                                                                                                "));
	}
}

rule("Track Player Name lengths and Set Spacing")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		(Global.NumMercysAlive != Count Of(All Living Players(Team 2)) || Global.NumMercysDead != Count Of(All Dead Players(Team 2)))
			== True;
		Global.SortedNames == 0;
	}

	actions
	{
		Global.SortedNames = 1;
		Wait(0.250, Ignore Condition);
		Global.SortedNames = Array(Sorted Array(All Living Players(Team 2), Slot Of(Current Array Element)), Sorted Array(All Dead Players(
			Team 2), Slot Of(Current Array Element)));
		Global.NameList[0] = Custom String("");
		Global.Spacing = 0;
		For Global Variable(NumMercysAlive, 0, Min(Count Of(All Living Players(Team 2)), 5), 1);
			Global.NameList[0] = Custom String("{0} {1}", Global.NameList[0], Global.SortedNames[0][Global.NumMercysAlive]);
			Global.Spacing += String Length(Global.SortedNames[0][Global.NumMercysAlive]);
		End;
		Global.PlayerNamesLength = Global.Spacing;
		If(Count Of(All Living Players(Team 2)) > 5);
			Global.NameList[0] = Custom String("{0}\n", Global.NameList[0]);
			Global.Spacing = 0;
			For Global Variable(NumMercysAlive, 5, Count Of(All Living Players(Team 2)), 1);
				Global.NameList[0] = Custom String("{0} {1}", Global.NameList[0], Global.SortedNames[0][Global.NumMercysAlive]);
				Global.Spacing += String Length(Global.SortedNames[0][Global.NumMercysAlive]);
			End;
			If(Global.PlayerNamesLength < Global.Spacing);
				Global.PlayerNamesLength = Global.Spacing;
			End;
		End;
		Global.NameList[1] = Custom String("");
		Global.Spacing = 0;
		For Global Variable(NumMercysDead, 0, Min(Count Of(All Dead Players(Team 2)), 5), 1);
			Global.NameList[1] = Custom String("{0} {1}", Global.NameList[1], Global.SortedNames[1][Global.NumMercysDead]);
			Global.Spacing += String Length(Global.SortedNames[1][Global.NumMercysDead]);
		End;
		If(Global.PlayerNamesLength < Global.Spacing);
			Global.PlayerNamesLength = Global.Spacing;
		End;
		If(Count Of(All Dead Players(Team 2)) > 5);
			Global.NameList[1] = Custom String("{0}\n", Global.NameList[1]);
			Global.Spacing = 0;
			For Global Variable(NumMercysDead, 5, Count Of(All Dead Players(Team 2)), 1);
				Global.NameList[1] = Custom String("{0} {1}", Global.NameList[1], Global.SortedNames[1][Global.NumMercysDead]);
				Global.Spacing += String Length(Global.SortedNames[1][Global.NumMercysDead]);
			End;
			If(Global.PlayerNamesLength < Global.Spacing);
				Global.PlayerNamesLength = Global.Spacing;
			End;
		End;
		Global.Spacing = Custom String("WWWWW");
		For Global Variable(PlayerNamesLength, 75 - Global.PlayerNamesLength, 0, -2);
			Global.Spacing = Custom String("{0}LLL", Global.Spacing);
		End;
		Global.SortedNames = 0;
	}
}

rule("SpawnSetter SUBROUTINE")
{
	event
	{
		Subroutine;
		SpawnSetter;
	}

	actions
	{
		If(Array Contains(Array(Map(Ayutthaya), Map(Black Forest), Map(Black Forest Winter), Map(Castillo), Map(Ecopoint: Antarctica), Map(
			Ecopoint: Antarctica Winter), Map(Ilios Lighthouse), Map(Ilios Ruins), Map(Ilios Well), Map(Lijiang Control Center), Map(
			Lijiang Control Center Lunar New Year), Map(Lijiang Garden), Map(Lijiang Garden Lunar New Year), Map(Lijiang Night Market),
			Map(Lijiang Night Market Lunar New Year), Map(Necropolis), Map(Nepal Sanctum), Map(Nepal Shrine), Map(Nepal Village), Map(
			Oasis City Center), Map(Oasis Gardens), Map(Oasis Gardens)), Current Map));
			Global.ExpectedGamemode = Game Mode(Elimination);
		Else If(Array Contains(Array(Map(Busan Downtown Lunar New Year), Map(Busan Sanctuary Lunar New Year)), Current Map));
		Else If(Array Contains(Array(Map(Antarctic Peninsula), Map(Busan), Map(Circuit royal), Map(Colosseo), Map(Esperança), Map(
				Hanamura), Map(Havana), Map(Hollywood), Map(Junkertown), Map(New Queen Street), Map(New Junk City), Map(Numbani), Map(Paraíso),
				Map(Rialto), Map(Runasapi), Map(Samoa), Map(Shambali Monastery), Map(Suravasa), Map(Watchpoint: Gibraltar), Map(Aatlis)),
				Current Map));
			If(Current Game Mode != Game Mode(Skirmish));
				Global.ExpectedGamemode = Game Mode(Skirmish);
			End;
		"should have , Map(Hanaoka)"
		Else If(Current Game Mode == Game Mode(Capture the Flag) || Current Game Mode == Game Mode(Skirmish));
			If(!Array Contains(Array(Map(Blizzard World), Map(Dorado), Map(Eichenwalde), Map(Horizon Lunar Colony), Map(Paris), Map(Route 66),
				Map(Temple of Anubis), Map(Volskaya Industries)), Current Map));
				Global.ExpectedGamemode = Game Mode(Team Deathmatch);
			End;
		End;
		If(Global.ExpectedGamemode != 0 && Current Game Mode != Global.ExpectedGamemode);
			Create HUD Text(All Players(All Teams), Custom String("{1} {0} is Not Supported!!", Current Map, Current Game Mode), Null, Null,
				Top, 0.695, Color(White), Null, Null, Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Custom String("Please Turn Off This Map! This is the Wrong Gamemode!"), Null, Null, Top,
				0.700, Color(White), Null, Null, Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Custom String("Instead of {0} it should be {1}", Current Game Mode,
				Global.ExpectedGamemode), Null, Null, Top, 0.710, Color(White), Null, Null, Visible To, Default Visibility);
			Create HUD Text(All Players(All Teams), Custom String("Game Will Restart in {0}s", Round To Integer(Global.ExpectedGamemode, Up)),
				Null, Null, Top, 0.720, Color(White), Null, Null, Visible To and String, Default Visibility);
			Global.ExpectedGamemode = 60;
			Chase Global Variable Over Time(ExpectedGamemode, 0, 60, None);
			Wait Until(Global.ExpectedGamemode == 0, 69);
			Restart Match;
		End;
		disabled If(Current Map == Map(Antarctic Peninsula));
		disabled Else If(Current Map == Map(Blizzard World) || Current Map == Map(Blizzard World Winter));
		If(Current Map == Map(Blizzard World));
			Global.TDMSpawnPositions = Array(Vector(35.750, 2.690, 78.500), Vector(3, -3.690, -14.500));
			Global.FencePosition = Array(Vector(-24, -9.200, 204), 0);
		Else If(Current Map == Map(Blizzard World Winter));
			Global.TDMSpawnPositions = Array(Vector(-35.370, -2.250, 147.310), Vector(-20.440, 2, 64.850));
		Else If(Current Map == Map(Busan));
			Global.TDMSpawnPositions = Array(Vector(275.279, 10.100, 210.837), Vector(163.832, 10.100, 258.750));
		Else If(Current Map == Map(Busan Downtown Lunar New Year));
			Global.TDMSpawnPositions = Array(Vector(-6.104, 15.930, -125.406), Vector(109.125, 15.930, -125.750));
		Else If(Current Map == Map(Busan Sanctuary Lunar New Year));
			Global.TDMSpawnPositions = Array(Vector(-393.250, 9.160, 160), Vector(-267.125, 9.160, 159.375));
		Else If(Current Map == Map(Château Guillard) || Current Map == Map(Château Guillard Halloween));
			Global.TDMSpawnPositions = Array(Vector(173.290, 7, 66.090), Vector(233.730, 2, 91.330));
		Else If(Current Map == Map(Circuit royal));
		Else If(Current Map == Map(Colosseo));
		Else If(Current Map == Map(Dorado) && Current Game Mode == Game Mode(Team Deathmatch));
			Global.TDMSpawnPositions = Array(Vector(158.330, 10.010, -7.880), Vector(68.130, 14.010, 16.260));
		Else If(Current Map == Map(Dorado));
			Global.TDMSpawnPositions = Array(Vector(73.750, 7, -11.360), Vector(-2.250, 0, 9.172));
			Global.FencePosition = Array(Vector(91, 7, -95), 0);
			disabled Else If(Current Map == Map(Eichenwalde) || Current Map == Map(Eichenwalde Halloween));
		Else If(Current Map == Map(Esperança));
		Else If(Current Map == Map(Eichenwalde));
			Global.TDMSpawnPositions = Array(Vector(12.254, 6.690, -89.700), Vector(-10.481, 0.690, -14.356));
			Global.FencePosition = Array(Vector(43, 6, -195), 0);
