rule("Rein: Kill to Respawn Dead")
{
	event
	{
		Player Earned Elimination;
		Team 1;
		Reinhardt;
	}

	conditions
	{
		Global.CombineBackStabReinResurrect == True;
		Is Alive(Event Player) == True;
		Is Dead(Farthest Player From(Event Player, Team Of(Event Player))) == True;
	}

	actions
	{
		Abort If(Global.CombineBackStabReinResurrect[1]);
		Set Status(All Dead Players(Team 1), Null, Invincible, 1.500);
		Wait Until(Global.DeadRein == Null, 5);
		Global.DeadRein = First Of(All Dead Players(Team Of(Event Player)));
		Call Subroutine(RespawnRein);
		Set Player Health(Farthest Player From(Event Player, Team 1), 2750);
	}
}

