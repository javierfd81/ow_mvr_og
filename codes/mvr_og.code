			Global.SkirmishSpawns = Randomized Array(Array(Array(Vector(16.271, 4.446, 88.218), Vector(64.163, 3.204, -75.644)), Array(Vector(
				14.638, 7.720, 89.746), Vector(-26.785, 1.429, -98.721))));
			Global.FencePosition = Array(Vector(-2, 0, 0), 0);
		Else If(Current Map == Map(Watchpoint: Gibraltar));
			Global.SkirmishSpawns = Randomized Array(Array(Array(Vector(25.455, -4.690, -73.279), Vector(31.501, -4.690, -132.383)), Array(
				Vector(107.342, -2, 69.369), Vector(79.438, -3, -19))));
			Global.FencePosition = Array(Vector(-47, -5, -34), 90);
		End;
		If(Array Contains(Array(Map(Antarctic Peninsula), Map(Samoa)), Current Map));
			Global.Score[3] = 2;
		Else If(Global.SkirmishSpawns == 1);
			Global.Score[3] = 6;
		Else;
			Global.Score[3] = 3;
		End;
		If(Global.FencePosition != 0);
			If(Global.FencePosition[1]);
				For Global Variable(Loop, 0, 16, 1);
					Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(150, Global.Loop, 0),
						Global.FencePosition[0] + Vector(-150, Global.Loop, 0), Null, Visible To);
				End;
				Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(150, 0, 0),
					Global.FencePosition[0] + Vector(150, 15, 0), Null, Visible To);
				Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(-150, 0, 0),
					Global.FencePosition[0] + Vector(-150, 15, 0), Null, Visible To);
			Else;
				For Global Variable(Loop, 0, 16, 1);
					Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(0, Global.Loop, 150),
						Global.FencePosition[0] + Vector(0, Global.Loop, -150), Null, Visible To);
				End;
				Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(0, 0, 150),
					Global.FencePosition[0] + Vector(0, 15, 150), Null, Visible To);
				Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(0, 0, -150),
					Global.FencePosition[0] + Vector(0, 15, -150), Null, Visible To);
				If(Current Map == Map(Blizzard World));
					For Global Variable(Loop, 16, 25, 1);
						Create Beam Effect(All Players(All Teams), Grapple Beam, Global.FencePosition[0] + Vector(0, Global.Loop, 150),
							Global.FencePosition[0] + Vector(0, Global.Loop, -134), Null, Visible To);
					End;
				End;
			End;
		End;
		Call Subroutine(SkirmishSpawnSetter);
	}
}

rule("SkirmishSpawnSetter SUBROUTINE")
{
	event
	{
		Subroutine;
		SkirmishSpawnSetter;
	}

	actions
	{
		If(Global.Score[7] + Global.Score[8] + Global.Score[2] >= Global.Score[3] || Total Time Elapsed < 15);
			Global.Score[7] = 0;
			Global.Score[8] = 0;
			Global.Score[2] = Global.Score[2] % 1;
			disabled If((Global.Score[0] + Global.Score[1]) % Global.Score[3] == 0);
			If(Global.SkirmishSpawns != 0 && Global.SkirmishSpawns != 1);
				Global.TDMSpawnPositions = First Of(Global.SkirmishSpawns);
				Modify Global Variable(SkirmishSpawns, Remove From Array By Index, 0);
			End;
			If(Total Time Elapsed > 15);
				Big Message(All Players(All Teams), Custom String("Switching {0} Maps!", Icon String(Recycle)));
				Wait(1, Ignore Condition);
			End;
			If(Current Map == Map(Antarctic Peninsula));
				"Labs"
				If(Y Component Of(Global.TDMSpawnPositions[0]) > 45);
					disabled Global.TeleporterPositions = Array(Vector(181.036, 45.530, 186.642), Vector(178.053, 45.690, 185.501), Vector(182.339, 45.280,
						177.742), Vector(179.433, 47.491, 177.732), Vector(182.622, 45.590, 166.255), Vector(179.512, 45.690, 166.235));
					Global.MercyRezScalar = 80;
				"Sublevel"
				Else If(Y Component Of(Global.TDMSpawnPositions[0]) < -150);
					Global.TeleporterPositions = Array(Vector(-92.613, -151.510, -21.786), Vector(-90.467, -151.048, -26.532), Vector(-83.692,
						-151.500, -20.287), Vector(-83.440, -151.048, -25.726), Vector(-72.165, -151.500, -20.166), Vector(-72.137, -151.048,
						-25.829));
					Global.MercyRezScalar = 75;
				"Icebreaker"
				Else;
					Global.TeleporterPositions = Array(Vector(369.886, -8.970, -239.281), Vector(374.618, -9.040, -239.475), Vector(363.092, -9.310,
						-227.851), Vector(367.616, -9.050, -227.931), Vector(361.312, -9.460, -220.465), Vector(364.325, -9.090, -217.519));
					Global.MercyRezScalar = 75;
				End;
			Else If(Current Map == Map(Samoa));
				"Downtown"
				If(X Component Of(Global.TDMSpawnPositions[0]) > 120);
					Global.TeleporterPositions = Array(Vector(163.540, 17.120, -208.274), Vector(156.461, 18.460, -205.578), Vector(156.699, 12.170,
						-224.912), Vector(149.449, 14.600, -220.687), Vector(163.540, -99, -208.274), Vector(163.540, -100, -208.274));
					Global.MercyRezScalar = 80;
				"Beach"
				Else If(X Component Of(Global.TDMSpawnPositions[0]) < -220);
					disabled Global.TeleporterPositions = Array(Vector(-241.200, 3.820, -128.355), Vector(-236.072, 14.060, -128.113), Vector(-245.800, 7,
						-111.630), Vector(-237.554, 10.200, -111.526), Vector(-240.113, 13, -85.418), Vector(-235.770, 13.950, -90.824));
					Global.MercyRezScalar = 80;
				"Volcano"
				Else;
					Global.TeleporterPositions = Array(Vector(-29.773, 347.060, 421.345), Vector(-32.488, 346.860, 422.813), Vector(-35.621, 340.560,
						403.815), Vector(-42.220, 342.990, 409.282), Vector(-52.771, 340.540, 390.773), Vector(-56.475, 346.750, 394.482));
					Global.MercyRezScalar = 75;
				End;
			Else If(Global.FencePosition != 0);
				If(Global.FencePosition[1]);
					If(Z Component Of(Global.TDMSpawnPositions[0]) > Z Component Of(Global.FencePosition[0]));
						Global.Score[4] = True;
						Global.Score[5] = Vector(0, 0.100, 1);
					Else;
						Global.Score[4] = False;
						Global.Score[5] = Vector(0, 0.100, -1);
					End;
				Else;
					If(X Component Of(Global.TDMSpawnPositions[0]) > X Component Of(Global.FencePosition[0]));
						Global.Score[4] = True;
						Global.Score[5] = Vector(1, 0.100, 0);
					Else;
						Global.Score[4] = False;
						Global.Score[5] = Vector(-1, 0.100, 0);
					End;
				End;
			End;
			If(!Global.Score[6]);
				For Global Variable(Loop, 0, Count Of(Global.TeleporterPositions), 1);
					Create Effect((Current Map == Map(New Junk City)) == (Current Map == Map(Suravasa)) || Match Time <= 160 ? All Players(Team 1)
						: Null, Ring, Color(Blue), Global.TeleporterPositions[Global.Loop], 1.500, Visible To);
					Create Effect((Current Map == Map(New Junk City)) == (Current Map == Map(Suravasa)) || Match Time <= 160 ? All Players(Team 2)
						: All Players(All Teams), Ring, Color(Gray), Global.TeleporterPositions[Global.Loop], 1.500, Visible To);
				End;
				", Map(Hanaoka)"
				If(Array Contains(Array(Map(Circuit royal), Map(Colosseo), Map(Esperança), Map(Junkertown), Map(New Junk City), Map(
					New Queen Street), Map(Numbani), Map(Paraíso), Map(Shambali Monastery), Map(Suravasa), Map(Watchpoint: Gibraltar)),
					Current Map));
					Global.Score[6] = True;
				End;
			End;
		End;
	}
}

rule("EnsureTDMSpawns SUBROUTINE")
{
	event
	{
		Subroutine;
		EnsureTDMSpawns;
	}

	actions
	{
		Resurrect(All Dead Players(All Teams));
		Teleport(Remove From Array(All Players(Team 1), Players Within Radius(Global.TDMSpawnPositions[0], 3, Team 1, Off)),
			Global.TDMSpawnPositions[0]);
		Teleport(Remove From Array(All Players(Team 2), Players Within Radius(Global.TDMSpawnPositions[1], 4.500, Team 2, Off)),
			Global.TDMSpawnPositions[1]);
	}
}

rule("ResetRound SUBROUTINE")
{
	event
	{
		Subroutine;
		ResetRound;
	}

	actions
	{
		Set Status(All Players(All Teams), Null, Invincible, 6);
		Start Forcing Throttle(All Players(All Teams), 0, 0, 0, 0, 0, 0);
		Set Ability 1 Enabled(All Players(All Teams), False);
		Set Jump Enabled(All Players(All Teams), False);
		Cancel Primary Action(All Living Players(All Teams));
		Call Subroutine(RemoveMomentum);
		Global.PlayerSlot = 0;
		While(Global.PlayerSlot < 2);
			Teleport(Players In Slot(Global.PlayerSlot, Team 1), Global.TDMSpawnPositions[0] + Vector(Random Real(-2, 2), 0.069, Random Real(
				-2, 2)));
			Global.PlayerSlot += 1;
		End;
		Global.PlayerSlot = 0;
		While(Global.PlayerSlot < 10);
			Teleport(Players In Slot(Global.PlayerSlot, Team 2), Global.TDMSpawnPositions[1] + Vector(Random Real(-3.069, 3.069), 0.069,
				Random Real(-3.069, 3.069)));
			Global.PlayerSlot += 1;
		End;
		Clear Status(All Players(All Teams), Knocked Down);
		Resurrect(All Dead Players(All Teams));
		Set Player Health(All Players(Team 1), Max Health(First Of(All Players(Team 1))));
		Set Player Health(All Players(Team 2), Max Health(First Of(All Players(Team 2))));
		Set Ultimate Charge(All Players(Team 1), 100);
		All Players(Team 1).LeaveSpawnTimer = 10;
		All Players(Team 2).LeaveSpawnTimer = 5;
		Call Subroutine(PlayerVariableSetter);
		Set Match Time(175);
		Start Rule(DisplayTips, Do Nothing);
		Call Subroutine(StartRoundMessages);
		Call Subroutine(EnsureTDMSpawns);
		Stop Forcing Throttle(All Players(All Teams));
		Set Ability 1 Enabled(All Players(All Teams), True);
		Set Jump Enabled(All Players(All Teams), True);
		Unpause Match Time;
		Enable Built-In Game Mode Music;
		Call Subroutine(MatchPointMessage);
		Global.GracePeriod = True;
		Wait(0.250, Ignore Condition);
		Global.RoundStart = True;
		Wait(5, Ignore Condition);
		Global.GracePeriod = False;
	}
}

rule("Joined Mid Round")
{
	event
	{
		Player Joined Match;
		All;
		All;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Is Game In Progress == True;
	}

	actions
	{
		If(Current Game Mode == Game Mode(Skirmish));
			Event Player.LeaveSpawnTimer = 10;
			Respawn(Event Player);
		End;
		Start Forcing Throttle(Event Player, 0, 0, 0, 0, 0, 0);
		Set Ability 1 Enabled(Event Player, False);
		Set Jump Enabled(Event Player, False);
		Skip If(!Global.TDMSpawnPositions, 25);
		If(Global.RoundStart && !Global.GracePeriod);
			If(Team Of(Event Player) == Team 1);
				Global.CombineBackStabReinResurrect[1] = True;
			End;
			Wait(0.690, Ignore Condition);
			Kill(Event Player, Null);
			Event Player.mercydeath = True;
			Teleport(Event Player, Vector(0, -40, 0));
			Wait(1.690, Ignore Condition);
			Event Player.mercydeath = False;
			Big Message(Event Player, Custom String("Sorry, round has already started, please wait until next round."));
		Else If(Team Of(Event Player) == Team 1);
			Wait(0.690, Ignore Condition);
			Teleport(Event Player, Global.TDMSpawnPositions[0] + Vector(Random Real(-2, 2), 0.069, Random Real(-2, 2)));
			Set Healing Received(Event Player, 0);
			Set Ultimate Charge(Event Player, 100);
		Else;
			Wait(0.690, Ignore Condition);
			Teleport(Event Player, Global.TDMSpawnPositions[1] + Vector(Random Real(-3.069, 3.069), 0.069, Random Real(-3.069, 3.069)));
			Set Healing Received(Event Player, 100);
		End;
		Event Player.IsInMap = True;
		If(Current Game Mode == Game Mode(Capture the Flag) || Current Game Mode == Game Mode(Skirmish));
			Disable Game Mode HUD(Event Player);
			Disable Game Mode In-World UI(Event Player);
		End;
		If(Global.RoundStart);
			Stop Forcing Throttle(Event Player);
			Set Ability 1 Enabled(Event Player, True);
			Set Jump Enabled(Event Player, True);
		End;
		Disable Built-In Game Mode Respawning(Event Player);
		Enable Death Spectate Target HUD(Event Player);
		If(Current Game Mode == Game Mode(Skirmish));
			Set Respawn Max Time(Event Player, 999);
		End;
	}
}

rule("Start Round")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Is Game In Progress == True;
	}

	actions
	{
		Create HUD Text(All Players(All Teams), Custom String("SETUP"), Null, Null, Top, 0.700, Color(White), Null, Null, Visible To,
			Default Visibility);
		Global.SetUpHUDText = Last Text ID;
		If(Current Game Mode == Game Mode(Capture the Flag));
			Wait(9, Ignore Condition);
		Else If(Current Game Mode == Game Mode(Skirmish));
			Wait(12, Ignore Condition);
			"Else If(Current Game Mode == Game Mode(Clash));"
			disabled Wait(12, Ignore Condition);
		End;
		Destroy HUD Text(Global.SetUpHUDText);
		Pause Match Time;
		Call Subroutine(ResetRound);
	}
}

rule("Draw HUD")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Is Game In Progress == True;
	}

	actions
	{
		Create HUD Text(All Players(Team 1), Null, Null, Custom String("{0}{1}", All Living Players(Team 1)[0] ? Custom String("{0}",
			All Living Players(Team 1)[0]) : Empty Array, All Living Players(Team 1)[1] ? Custom String("\n{0}", All Living Players(Team 1)
			[1]) : Empty Array), Left, -0.690, Null, Null, Custom Color(0, 195, 255, 175), Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 1), Null, Null, Custom String("{0}{1}", All Dead Players(Team 1)[0] ? Custom String("{0}",
			All Dead Players(Team 1)[0]) : Empty Array, All Dead Players(Team 1)[1] ? Custom String("\n{0}", All Dead Players(Team 1)[1])
			: Empty Array), Left, 0, Null, Null, Custom Color(69, 69, 69, 169), Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 1), Null, Null, Global.NameList[0], Right, -0.690, Null, Null, Custom Color(255, 0, 42, 175),
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 1), Null, Null, Global.NameList[1], Right, 0, Null, Null, Custom Color(69, 69, 69, 169),
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Custom String("{0}{1}", All Living Players(Team 1)[0] ? Custom String("{0}",
			All Living Players(Team 1)[0]) : Empty Array, All Living Players(Team 1)[1] ? Custom String("\n{0}", All Living Players(Team 1)
			[1]) : Empty Array), Right, -0.690, Null, Null, Custom Color(255, 0, 42, 175), Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Custom String("{0}{1}", All Dead Players(Team 1)[0] ? Custom String("{0}",
			All Dead Players(Team 1)[0]) : Empty Array, All Dead Players(Team 1)[1] ? Custom String("\n{0}", All Dead Players(Team 1)[1])
			: Empty Array), Right, 0, Null, Null, Custom Color(69, 69, 69, 169), Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Global.NameList[0], Left, -0.690, Null, Null, Custom Color(0, 195, 255, 175),
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Global.NameList[1], Left, 0, Null, Null, Custom Color(69, 69, 69, 169),
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 1), Null, Null, Custom String("\nWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWW"),
			Left, -1, Null, Null, Null, Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Custom String("\nWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWWW"),
			Right, -1, Null, Null, Null, Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 1), Null, Null, Custom String("\n{0}", Global.Spacing), Right, -1, Null, Null, Null,
			Visible To and String, Default Visibility);
		Create HUD Text(All Players(Team 2), Null, Null, Custom String("\n{0}", Global.Spacing), Left, -1, Null, Null, Null,
			Visible To and String, Default Visibility);
	}
}

rule("Reins killed all Mercys")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Global.RoundStart == True;
		Match Time > 0;
		Number Of Dead Players(Team 2) == Number Of Players(Team 2);
	}

	actions
	{
		Global.RoundStart = False;
		Modify Team Score(Team 1, 1);
		Global.Score[0] += 1;
		Global.Score[7] += 1;
		Big Message(All Players(All Teams), Custom String("{0} Reins Win", Hero Icon String(Hero(Reinhardt))));
		Call Subroutine(EndRound);
	}
}

rule("Mercys killed all Reins")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Global.RoundStart == True;
		Match Time > 0;
		Number Of Dead Players(Team 1) == Number Of Players(Team 1);
	}

	actions
	{
		Global.RoundStart = False;
		Modify Team Score(Team 2, 1);
		Global.Score[1] += 1;
		Global.Score[8] += 1;
		Big Message(All Players(All Teams), Custom String("{0} Mercys Win", Hero Icon String(Hero(Mercy))));
		Call Subroutine(EndRound);
	}
}

rule("Round time ended")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Global.RoundStart == True;
		Match Time == 0;
	}

	actions
	{
		Global.RoundStart = False;
		If(Number Of Players(Team 1) - Number Of Dead Players(Team 1) > Number Of Players(Team 2) - Number Of Dead Players(Team 2));
			Modify Team Score(Team 1, 1);
			Global.Score[0] += 1;
			Global.Score[7] += 1;
			Big Message(All Players(All Teams), Custom String("{0} Reins Win", Hero Icon String(Hero(Reinhardt))));
		Else If(Number Of Players(Team 1) - Number Of Dead Players(Team 1) < Number Of Players(Team 2) - Number Of Dead Players(Team 2));
			Modify Team Score(Team 2, 1);
			Global.Score[1] += 1;
			Global.Score[8] += 1;
			Big Message(All Players(All Teams), Custom String("{0} Mercys Win", Hero Icon String(Hero(Mercy))));
		Else;
			Global.Score[2] += 0.500;
			Big Message(All Players(All Teams), Custom String("{0} Draw {1}", Hero Icon String(Hero(Mercy)), Hero Icon String(Hero(
				Reinhardt))));
		End;
		Call Subroutine(EndRound);
	}
}

rule("EndRound SUBROUTINE")
{
	event
	{
		Subroutine;
		EndRound;
	}

	actions
	{
		Disable Built-In Game Mode Music;
		Set Slow Motion(33.330);
		Set Aim Speed(All Players(All Teams), 33.330);
		If(Global.Score[0] == 3 || Number Of Players(Team 2) == 0);
			Enable Built-In Game Mode Music;
			Declare Team Victory(Team 1);
		Else If(Global.Score[1] == 3 || Number Of Players(Team 1) == 0);
			Enable Built-In Game Mode Music;
			Declare Team Victory(Team 2);
		Else;
			Pause Match Time;
			If(Count Of(Global.SkirmishSpawns) > 0);
				disabled If(Global.SkirmishSpawns != 0 && Global.SkirmishSpawns != 1 && Global.Score[2]);
				Call Subroutine(SkirmishSpawnSetter);
			End;
			Wait(2.369, Ignore Condition);
			Set Slow Motion(100);
			Set Aim Speed(All Players(All Teams), 100);
			Stop Forcing Player Outlines(All Players(All Teams), All Players(All Teams));
			Global.RevealedMercys = False;
			Call Subroutine(ResetRound);
		End;
	}
}

rule("MatchPointMessage SUBROUTINE")
{
	event
	{
		Subroutine;
		MatchPointMessage;
	}

	actions
	{
		If(Team Score(Team 1) == 2);
			Big Message(All Players(All Teams), Custom String("{0} Rein Match Point", Hero Icon String(Hero(Reinhardt))));
		End;
		If(Team Score(Team 2) == 2);
			Big Message(All Players(All Teams), Custom String("{0} Mercy Match Point", Hero Icon String(Hero(Mercy))));
		End;
	}
}

rule("Fix Death Spectate Perspective")
{
	event
	{
		Player Died;
		All;
		All;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Event Player.perspectivetoggle == True;
	}

	actions
	{
		Event Player.perspectivetoggle = False;
		Event Player.TDMDeathSpectate = True;
	}
}

rule("Revert Perspective when alive")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Current Game Mode != Game Mode(Elimination);
		Is Alive(Event Player) == True;
		Event Player.TDMDeathSpectate == True;
	}

	actions
	{
		Event Player.perspectivetoggle = True;
		Event Player.TDMDeathSpectate = False;
	}
}

rule("RemoveMomentum SUBROUTINE")
{
	event
	{
		Subroutine;
		RemoveMomentum;
	}

	actions
	{
		Apply Impulse(All Living Players(All Teams), Left, 0.069, To World, Cancel Contrary Motion);
		Apply Impulse(All Living Players(All Teams), Right, 0.069, To World, Cancel Contrary Motion);
		Apply Impulse(All Living Players(All Teams), Forward, 0.069, To World, Cancel Contrary Motion);
		Apply Impulse(All Living Players(All Teams), Backward, 0.069, To World, Cancel Contrary Motion);
		Apply Impulse(All Living Players(All Teams), Up, 0.069, To World, Cancel Contrary Motion);
		Apply Impulse(All Living Players(All Teams), Down, 1, To World, Cancel Contrary Motion);
	}
}

rule("StartRoundMessages SUBROUTINE")
{
	event
	{
		Subroutine;
		StartRoundMessages;
	}

	actions
	{
		Wait(0.697, Ignore Condition);
		For Global Variable(TDMCountDown, 3, 0, -1);
			Big Message(All Players(All Teams), Custom String("{0}", Global.TDMCountDown));
			Wait(0.250, Ignore Condition);
			Play Effect(All Players(All Teams), Debuff Impact Sound, Color(White), Global.TDMSpawnPositions[0], 200);
			Play Effect(All Players(All Teams), Debuff Impact Sound, Color(White), Global.TDMSpawnPositions[1], 200);
			Wait(1.750, Ignore Condition);
		End;
		Big Message(All Players(All Teams), Custom String("Go!"));
		Wait(0.250, Ignore Condition);
		Play Effect(All Players(All Teams), Explosion Sound, Color(White), Global.TDMSpawnPositions[0], 200);
		Play Effect(All Players(All Teams), Explosion Sound, Color(White), Global.TDMSpawnPositions[1], 200);
		Play Effect(All Players(All Teams), Ring Explosion Sound, Color(White), Global.TDMSpawnPositions[0], 200);
		Play Effect(All Players(All Teams), Ring Explosion Sound, Color(White), Global.TDMSpawnPositions[1], 200);
	}
}

