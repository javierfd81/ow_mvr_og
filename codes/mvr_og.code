rule("Check Mercy is using beam")
{
	event
	{
		Ongoing - Each Player;
		Team 2;
		All;
	}

	conditions
	{
		Weapon(Event Player) == 1;
		Is Firing Primary(Event Player) != Is Firing Secondary(Event Player);
	}

	actions
	{
		Wait Until(Is True For Any(Players in View Angle(Event Player, Team 2, 30), Distance Between(Event Player, Current Array Element)
			<= 15.500 && Is In Line of Sight(Event Player, Current Array Element, Barriers Do Not Block LOS) && Is Alive(
			Current Array Element)), 9999);
		Abort If Condition Is False;
		Event Player.MercyIsBeaming = True;
		Wait Until(Weapon(Event Player) != 1 || !(Is Firing Primary(Event Player) || Is Firing Secondary(Event Player)), 9999);
		Event Player.MercyIsBeaming = False;
	}
}

rule("Mercy sacrifice health for extra ga")
{
	event
	{
		Ongoing - Each Player;
		Team 2;
		All;
	}

	conditions
	{
		Workshop Setting Toggle(Custom String("Mercy Settings"), Custom String("Sacrifice Health for GA Charge"), False, 0) == True;
		Event Player.MercyGACount < 1;
		Is Button Held(Event Player, Button(Ability 1)) == True;
	}

	actions
	{
		Damage(Event Player, Null, 10);
		If(Event Player.MercyGACount >= 0.900);
			Event Player.MercyGACount = 1;
			Play Effect(Event Player, Buff Impact Sound, Null, Event Player, 16);
			Set Ability 1 Enabled(Event Player, True);
		Else;
			Event Player.MercyGACount += Random Real(0, 0.100);
		End;
		If(Health(Event Player) <= 1);
			Event Player.mercydeath = True;
			Wait(0.250, Ignore Condition);
			Event Player.mercydeath = False;
		End;
	}
}

disabled rule("======================================================REIN POWER UPS============================================================")
{
	event
	{
		Ongoing - Global;
	}
