			"{2}Hold {0} and {1} to Show Rein List", Input Binding String(Button(Interact)), Input Binding String(Button(Secondary Fire)),
			Global.CurrentSeekers[2]), Null, Right, 6, Null, Color(Gray), Null, Visible To and String, Default Visibility);
		Create HUD Text(Number Of Players(All Teams) < 12 ? All Players(Team 2) : Null, Null, Null, Is Button Held(Local Player, Button(
			Interact)) && Is Button Held(Local Player, Button(Secondary Fire)) ? Empty Array : Custom String(
			"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\r\nn\n\n\n\n\n\n\n\n\n\n"), Right, 7, Null, Null, Null,
			Visible To and String, Default Visibility);
		Create HUD Text(Number Of Players(All Teams) < 12 ? All Players(Team 2) : Null, Null, Global.CurrentSeekers[1], Null, Right, 8,
			Null, Color(White), Null, Visible To and String, Default Visibility);
	}
}

disabled rule("Switch Reins at end of round (new unreliable but more attempted functionality)")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Is Match Complete == True;
		Number Of Players(All Teams) < 12;
	}

	actions
	{
		Set Slow Motion(100);
		Wait(25.400, Abort When False);
		Global.CurrentSeekers = Filtered Array(All Players(Team 1), Current Array Element != 0);
		Global.NextSeekers = Array Slice(Randomized Array(Filtered Array(Global.NextSeekers, Current Array Element != 0)), 0, 2);
		If(Count Of(Global.NextSeekers) < 2 && Count Of(All Players(All Teams) > 7));
			Modify Global Variable(NextSeekers, Append To Array, Array Slice(Randomized Array(All Players(Team 2)), 0, 2 - Count Of(
				Global.NextSeekers)));
		Else If(Count Of(Global.NextSeekers) == 0);
			Modify Global Variable(NextSeekers, Append To Array, Random Value In Array(All Players(Team 2)));
		End;
		If(Number Of Players(Team 1) == 2);
			If(Team Of(Global.NextSeekers[0]) != Team 1);
				Move Player to Team(Global.CurrentSeekers[0], Team 2, -1);
				Move Player to Team(Global.NextSeekers[0], Team 1, -1);
			End;
			If(Count Of(Global.NextSeekers) > 1);
				If(Team Of(Global.NextSeekers[1]) != Team 1);
					Move Player to Team(Global.CurrentSeekers[1], Team 2, -1);
					Move Player to Team(Global.NextSeekers[1], Team 1, -1);
				End;
			Else If(Count Of(All Players(All Teams)) < 8);
				Move Player to Team(Global.CurrentSeekers[1], Team 2, -1);
			End;
		Else;
			If(Team Of(Global.NextSeekers[0]) != Team 1);
				Move Player to Team(Global.NextSeekers[0], Team 1, -1);
				Move Player to Team(Global.CurrentSeekers[0], Team 2, -1);
			End;
			If(Count Of(Global.NextSeekers) > 1);
				If(Team Of(Global.NextSeekers[1]) != Team 1);
					Move Player to Team(Global.NextSeekers[1], Team 1, -1);
					Move Player to Team(Global.CurrentSeekers[1], Team 2, -1);
				End;
			End;
		End;
		Wait(0.550, Ignore Condition);
		Restart Match;
	}
}

rule("Switch Reins at end of round test")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Number Of Players(All Teams) < 12;
		Is True For All(Array(Button(Ability 1), Button(Ability 2), Button(Reload)), Is Button Held(Host Player, Current Array Element))
			== True;
	}

	actions
	{
