rule("Last Hero Remaining")
{
	event
	{
		Player Died;
		All;
		All;
	}

	conditions
	{
		(Count Of(All Living Players(Team 1)) == 1 || Count Of(All Living Players(Team 2)) == 1) == True;
		(Global.RoundStart || Current Game Mode == Game Mode(Elimination)) == True;
	}

	actions
	{
		Wait Until(!Event Player.mercydeath, 0.260);
		Abort If(Event Player.mercydeath);
		If(Count Of(All Living Players(Team 1)) == 1 && Team Of(Event Player) == Team 1);
			Big Message(All Players(All Teams), Custom String("Last Rein Remaining"));
			If(Is True For Any(Array(Game Mode(Capture the Flag), Game Mode(Team Deathmatch)), Current Array Element == Current Game Mode));
				Play Effect(All Players(Team 1), Ring Explosion Sound, Null, First Of(All Living Players(Team 1)), 99);
			End;
		Else If(Count Of(All Living Players(Team 2)) == 1 && Team Of(Event Player) == Team 2);
			Big Message(All Players(All Teams), Custom String("Last Mercy Remaining"));
			If(Is True For Any(Array(Game Mode(Capture the Flag), Game Mode(Team Deathmatch)), Current Array Element == Current Game Mode));
				Play Effect(All Players(Team 2), Ring Explosion Sound, Null, First Of(All Living Players(Team 2)), 99);
			End;
		End;
	}
}

