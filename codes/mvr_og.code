rule("WallBoop SUBROUTINE")
{
	event
	{
		Subroutine;
		WallBoop;
	}

	actions
	{
		Abort If(!Global.RoundStart);
		Wait(0.050, Ignore Condition);
		Abort If(Event Player.IsImmuneToWall);
		If(Is Using Ability 1(Event Player));
			Cancel Primary Action(Event Player);
		End;
		Set Ability 1 Enabled(Event Player, False);
		Start Damage Over Time(Event Player, Null, 9999, 40);
		Event Player.WallDamageOT = Last Damage Over Time ID;
		Set Move Speed(Event Player, 30);
		Call Subroutine(WallBoop2);
		If(Team Of(Event Player) == Team 1 || Event Player.MercyGACount > 0);
			Set Ability 1 Enabled(Event Player, True);
		End;
		Set Move Speed(Event Player, 100);
		Stop Damage Over Time(Event Player.WallDamageOT);
	}
}

rule("WallBoop2 SUBROUTINE")
{
	event
	{
		Subroutine;
		WallBoop2;
	}

	actions
	{
		Apply Impulse(Event Player, Global.Score[5], 20, To World, Cancel Contrary Motion);
		Wait(0.250, Ignore Condition);
		Loop If Condition Is True;
	}
}

