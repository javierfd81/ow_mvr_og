{
	event
	{
		Ongoing - Each Player;
		All;
		Reinhardt;
	}

	conditions
	{
		Is In Air(Event Player) == True;
		Is Button Held(Event Player, Button(Jump)) == True;
		Event Player.ReinJumpCount >= 1;
		(Has Status(Event Player, Frozen) || Has Status(Event Player, Knocked Down) || Has Status(Event Player, Stunned) || Has Status(
			Event Player, Hacked) || Has Status(Event Player, Asleep) || Has Status(Event Player, Rooted)) == False;
		Event Player.Allowed == True;
		Workshop Setting Toggle(Custom String("Rein Settings"), Custom String("Multi Jump"), True, 0) == True;
		disabled Event Player.DoubleJump == True;
	}

	actions
	{
		Event Player.ReinJumpCount = Event Player.ReinJumpCount - 1;
		Apply Impulse(Event Player, Vector(0, 1, 0), 10, To World, Cancel Contrary Motion);
	}
}

