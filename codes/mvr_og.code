			Global.TDMSpawnPositions = Array(Vector(-69, 10.750, -27.500), Vector(-85, 13, -106.710));
		Else If(Current Map == Map(Paris));
			Global.TDMSpawnPositions = Array(Vector(-54.352, 12, 13.908), Vector(6.693, 10, -65.377));
			Global.FencePosition = Array(Vector(-70, 11, -142.250), 0);
		Else If(Current Map == Map(Petra));
			Global.TDMSpawnPositions = Array(Vector(2, -6, -13), Vector(4.500, -12.800, 48));
		Else If(Current Map == Map(Rialto));
			Global.TDMSpawnPositions = Array(Vector(10, 1, 86.125), Vector(-2.627, -1, -6.495));
		Else If(Current Map == Map(Route 66) && Current Game Mode == Game Mode(Team Deathmatch));
