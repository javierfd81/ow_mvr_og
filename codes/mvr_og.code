rule("Add/remove player from Seeker Priority List")
{
	event
	{
		Ongoing - Each Player;
		All;
		All;
	}

	conditions
	{
		Is Button Held(Event Player, Button(Interact)) == True;
		Is Button Held(Event Player, Button(Secondary Fire)) == True;
		Is Button Held(Event Player, Button(Primary Fire)) == True;
		Is Match Complete != True;
	}

	actions
	{
		If(Array Contains(Global.NextSeekers, Event Player));
			Small Message(Event Player, Custom String("You have been removed from the Seekers queue"));
			Modify Global Variable(NextSeekers, Remove From Array By Value, Event Player);
			Global.CurrentSeekers[0] = Custom String("{0}{1}", Global.NextSeekers[0], Global.CurrentSeekers[2]);
			Global.CurrentSeekers[1] = Custom String("{1}{0}", Global.NextSeekers[0], Global.CurrentSeekers[2]);
			If(Count Of(Global.NextSeekers) > 0);
				For Global Variable(Loop, 1, Count Of(Global.NextSeekers), 1);
					Global.CurrentSeekers[0] = Custom String("{0}\n{1}{2}", Global.CurrentSeekers[0], Global.NextSeekers[Global.Loop],
						Global.CurrentSeekers[2]);
					Global.CurrentSeekers[1] = Custom String("{0}\n{2}{1}", Global.CurrentSeekers[1], Global.NextSeekers[Global.Loop],
						Global.CurrentSeekers[2]);
				End;
			Else;
				Global.CurrentSeekers[0] = Custom String("");
				Global.CurrentSeekers[1] = Custom String("");
			End;
		Else;
			If(Count Of(Global.NextSeekers) < 6);
				Small Message(Event Player, Custom String("You have been added to the Seekers queue"));
				Modify Global Variable(NextSeekers, Append To Array, Event Player);
				If(Count Of(Global.NextSeekers) == 1);
					Global.CurrentSeekers[0] = Custom String("{0}{1}", Global.NextSeekers[0], Global.CurrentSeekers[2]);
					Global.CurrentSeekers[1] = Custom String("{1}{0}", Global.NextSeekers[0], Global.CurrentSeekers[2]);
				Else;
					Global.CurrentSeekers[0] = Custom String("{0}\n{1}{2}", Global.CurrentSeekers[0], Last Of(Global.NextSeekers),
						Global.CurrentSeekers[2]);
					Global.CurrentSeekers[1] = Custom String("{0}\n{2}{1}", Global.CurrentSeekers[1], Last Of(Global.NextSeekers),
						Global.CurrentSeekers[2]);
				End;
			Else;
				Small Message(Event Player, Custom String("Sorry, queue is too full"));
			End;
		End;
		Wait(1, Ignore Condition);
	}
}

