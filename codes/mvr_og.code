rule("Boop Rein into skybox + reduce mercy rez cd + backstab bonus damage")
{
	event
	{
		Player Received Knockback;
		All;
		Reinhardt;
	}

	actions
	{
		If(Global.CombineBackStabReinResurrect && !Is In View Angle(Event Player, Attacker, 110));
			If(Angle Between Vectors(Facing Direction Of(Event Player), Facing Direction Of(Attacker)) <= 85);
				Play Effect(All Players(All Teams), Debuff Impact Sound, Color(Red), Position Of(Event Player), 100);
				If(Number Of Players(Team 1) == 1 || Global.CombineBackStabReinResurrect[1]);
					Damage(Event Player, Attacker, 650);
				Else;
					Kill(Event Player, Attacker);
				End;
			End;
		End;
		Apply Impulse(Event Player, Vector Towards(Attacker, Event Player), 5, To World, Cancel Contrary Motion);
		Apply Impulse(Event Player, Up, 69, To World, Cancel Contrary Motion);
		Set Ability Cooldown(Attacker, Button(Ability 2), Ability Cooldown(Attacker, Button(Ability 2)) - 3);
		Set Ability Cooldown(Attacker, Button(Secondary Fire), Ability Cooldown(Attacker, Button(Secondary Fire)) - 3);
		If(Attacker.TeleporterCD > 2);
			Attacker.TeleporterCD -= 2;
		Else;
			Attacker.TeleporterCD = 0;
		End;
	}
}

