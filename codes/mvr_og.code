rule("Castillo, EcoPoint: Antarctica, Workshop Maps GA, FS, M1 Turned OFF")
{
	event
	{
		Ongoing - Global;
	}

	conditions
	{
		Array Contains(Array(Map(Castillo), Map(Ecopoint: Antarctica), Map(Ecopoint: Antarctica Winter), Map(Rialto), Map(
			Workshop Expanse), Map(Workshop Expanse Night), Map(Workshop Green Screen)), Current Map) == True;
		Is In Setup == True;
		Global.ExperimentalChargeOnlyMap != True;
	}

	actions
	{
		Global.ExperimentalChargeOnlyMap = Workshop Setting Toggle(Custom String("General"), Custom String("Experimental Charge Only"),
			False, 0);
		Wait(1.250, Ignore Condition);
		If(Global.ExperimentalChargeOnlyMap);
			Big Message(Players On Hero(Hero(Reinhardt), All Teams), Custom String("Hammer Swing Reduces Move Speed For This Map"));
			Big Message(Players On Hero(Hero(Mercy), All Teams), Custom String("GA Charges Reduced For This Map"));
			All Players(Team 2).MercyGACount = 1;
		Else;
			Global.ChargeOnlyMap = True;
			Set Primary Fire Enabled(Players On Hero(Hero(Reinhardt), All Teams), False);
			Set Ability 1 Enabled(Players On Hero(Hero(Mercy), All Teams), False);
			Set Ability 2 Enabled(All Players(Team 2), False);
			Wait(1.690, Ignore Condition);
			Big Message(Players On Hero(Hero(Reinhardt), All Teams), Custom String("Hammer Swing Disabled For This Map"));
			Big Message(Players On Hero(Hero(Mercy), All Teams), Custom String("Rez Disabled For This Map"));
			Big Message(Players On Hero(Hero(Mercy), All Teams), Custom String("GA Disabled For This Map"));
			If(Current Map != Map(Castillo));
				Set Ability 2 Enabled(Players On Hero(Hero(Reinhardt), All Teams), False);
				Big Message(Players On Hero(Hero(Reinhardt), All Teams), Custom String("Fire Strike Disabled For This Map"));
			End;
		End;
	}
}

rule("Experimental Alternative To Charge Only Maps")
{
	event
	{
		Ongoing - Each Player;
		All;
		Reinhardt;
	}

	conditions
	{
		Global.ExperimentalChargeOnlyMap == True;
		Is Firing Primary(Event Player) == True;
	}

	actions
	{
		If(Horizontal Speed Of(Event Player) > 12.400);
			Apply Impulse(Event Player, -1 * Velocity Of(Event Player), Horizontal Speed Of(Event Player) - 12.400, To World,
				Incorporate Contrary Motion);
		End;
		Set Move Speed(Event Player, 75);
		Wait Until(!Is Firing Primary(Event Player), 180);
		Set Move Speed(Event Player, 100);
	}
}

